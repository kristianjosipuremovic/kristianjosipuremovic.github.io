---
import personalData from '../data/personal.json';
import siteData from '../data/site.json';

const currentYear = new Date().getFullYear();
---

<footer class="site-foot" transition:persist="site-foot">
  <div class="foot-inner">
    <div class="foot-rule" aria-hidden="true"></div>
    <div class="foot-grid">
      <div class="foot-brand">
        <p class="foot-name">{personalData.name}</p>
        <p class="foot-tag">{siteData.tagline}</p>
      </div>

      <nav class="foot-socials" aria-label="Social">
        {personalData.github && (
          <a href={personalData.github} target="_blank" rel="noopener noreferrer" class="foot-icon" aria-label="GitHub">
            <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="1.4" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 19c-4 1.5-4-2-6-2.5M15 21v-3.5a3 3 0 0 0-1-2.3c3 -.3 6 -1.5 6 -6.5 a4.7 4.7 0 0 0 -1.3 -3.3 a4.4 4.4 0 0 0 -.1 -3.3 s-1.1 -.3 -3.6 1.3 a12.3 12.3 0 0 0 -6.4 0 C6.1 1.8 5 2.1 5 2.1 a4.4 4.4 0 0 0 -.1 3.3 A4.7 4.7 0 0 0 3.6 8.7 c0 5 3 6.1 6 6.5 a3 3 0 0 0 -1 2.3 V21"/>
            </svg>
          </a>
        )}
        {personalData.linkedin && (
          <a href={personalData.linkedin} target="_blank" rel="noopener noreferrer" class="foot-icon" aria-label="LinkedIn">
            <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="1.4" aria-hidden="true">
              <rect x="2" y="2" width="20" height="20" rx="0.5"/>
              <line x1="7" y1="10" x2="7" y2="17"/>
              <circle cx="7" cy="6.5" r="0.8"/>
              <path d="M11 17v-7M11 13a3 3 0 0 1 6 0v4"/>
            </svg>
          </a>
        )}
        {personalData.email && (
          <a href={`mailto:${personalData.email}`} class="foot-icon" aria-label="Email">
            <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="1.4" aria-hidden="true">
              <rect x="2.5" y="5" width="19" height="14"/>
              <path d="M2.5 6l9.5 7 9.5 -7"/>
            </svg>
          </a>
        )}
      </nav>

      <div class="foot-meta">
        <a href="/now" class="foot-utility">Now</a>
        <span class="foot-sep" aria-hidden="true">·</span>
        <a href="/reading" class="foot-utility">Reading</a>
        <span class="foot-sep" aria-hidden="true">·</span>
        <a href="/rss.xml" class="foot-utility">RSS</a>
      </div>
    </div>

    <div class="foot-base">
      <span class="foot-copy">© {currentYear} {personalData.name}</span>
    </div>
  </div>
</footer>

<style>
  .site-foot {
    background: var(--bg);
    border-top: 1px solid var(--line);
  }

  .foot-inner {
    max-width: 80rem;
    margin: 0 auto;
    padding: 3rem 1.25rem 2rem;
  }
  @media (min-width: 768px) {
    .foot-inner { padding: 3.5rem 2rem 2rem; }
  }

  .foot-rule {
    height: 1px;
    background: linear-gradient(90deg, transparent 0%, var(--line-strong) 15%, var(--line-bright) 50%, var(--line-strong) 85%, transparent 100%);
    margin-bottom: 2.5rem;
    opacity: 0.6;
  }

  .foot-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.75rem;
    align-items: start;
  }
  @media (min-width: 640px) {
    .foot-grid {
      grid-template-columns: 1fr auto;
      gap: 2rem;
    }
  }

  .foot-brand { display: flex; flex-direction: column; gap: 0.25rem; }
  .foot-name {
    font-family: var(--font-display);
    font-size: 0.78rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.18em;
    color: var(--text);
    margin: 0;
  }
  .foot-tag {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    letter-spacing: 0.05em;
    color: var(--text-dimmer);
    margin: 0;
  }

  .foot-socials {
    display: flex;
    gap: 0.85rem;
    align-items: center;
  }
  @media (min-width: 640px) {
    .foot-socials { grid-column: 2; grid-row: 1; }
  }

  .foot-icon {
    color: var(--text-dim);
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 30px;
    height: 30px;
    border: 1px solid var(--line);
    transition: color 0.2s var(--ease-shutter), border-color 0.2s var(--ease-shutter), transform 0.25s var(--ease-shutter);
  }
  .foot-icon:hover {
    color: var(--text);
    border-color: var(--line-bright);
    transform: translate(-1px, -1px);
  }

  .foot-meta {
    display: flex;
    gap: 0.5rem;
    align-items: center;
    font-family: var(--font-display);
    font-size: 0.65rem;
    text-transform: uppercase;
    letter-spacing: 0.18em;
  }
  @media (min-width: 640px) {
    .foot-meta { grid-column: 1 / -1; grid-row: 2; margin-top: 0.25rem; }
  }
  .foot-utility { color: var(--text-dim); text-decoration: none; transition: color 0.2s ease; }
  .foot-utility:hover { color: var(--text); }
  .foot-sep { color: var(--text-dimmer); }

  .foot-base {
    margin-top: 2.5rem;
    padding-top: 1.25rem;
    border-top: 1px solid var(--line);
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 1rem;
    flex-wrap: wrap;
  }
  .foot-copy {
    font-family: var(--font-mono);
    font-size: 0.68rem;
    color: var(--text-dimmer);
    letter-spacing: 0.04em;
  }
</style>
