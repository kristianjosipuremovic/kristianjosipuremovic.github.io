---
import personalData from '../data/personal.json';
import menuData from '../data/menu.json';
import { getSocialLinks } from '../lib/socialLinks';

const currentYear = new Date().getFullYear();
const socialLinks = getSocialLinks(personalData as unknown as Record<string, string | string[]>);
const navLinks = menuData.sections.map((s) => ({ label: s.label, href: s.href }));
---

<footer id="site-footer" class="site-footer">
  <div class="container mx-auto px-4 sm:px-6 lg:px-8 max-w-4xl py-12">

    <div class="footer-grid">
      <div class="footer-brand">
        <p class="footer-name">{personalData.name}</p>
        <a href={`mailto:${personalData.email}`} class="footer-email">{personalData.email}</a>
        <div class="footer-socials">
          {socialLinks.map((link) => (
            <a href={link.url} target="_blank" rel="noopener noreferrer" class="footer-social" aria-label={link.label}>
              <iconify-icon icon={link.icon} width="18" height="18" aria-hidden="true" />
            </a>
          ))}
        </div>
      </div>

      <nav class="footer-nav" aria-label="Footer navigation">
        {navLinks.map((link) => (
          <a href={link.href} class="footer-nav-link">{link.label}</a>
        ))}
      </nav>
    </div>

    <div class="footer-bottom">
      <p class="footer-copy">© {currentYear} {personalData.name}</p>
      <div class="footer-utils">
        <a href="/now" class="footer-util-link">Now</a>
        <a href="/reading" class="footer-util-link">Reading</a>
        <a href="/rss.xml" class="footer-util-link">RSS</a>
      </div>
    </div>

  </div>
</footer>

<style>
  .site-footer {
    border-top: 1px solid var(--border);
    background: var(--bg);
  }

  .footer-grid {
    display: flex;
    flex-direction: column;
    gap: 2rem;
    margin-bottom: 2.5rem;
  }
  @media (min-width: 640px) {
    .footer-grid {
      flex-direction: row;
      justify-content: space-between;
      align-items: flex-start;
    }
  }

  .footer-brand {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }

  .footer-name {
    font-size: 0.9rem;
    font-weight: 600;
    color: var(--text);
    margin: 0;
  }

  .footer-email {
    font-size: 0.8rem;
    color: var(--text-dimmer);
    text-decoration: none;
    transition: color 0.2s ease;
  }
  .footer-email:hover { color: var(--text-muted); }

  .footer-socials {
    display: flex;
    gap: 0.75rem;
    margin-top: 0.5rem;
  }

  .footer-social {
    color: var(--text-dimmer);
    display: inline-flex;
    align-items: center;
    transition: color 0.2s ease, transform 0.2s ease;
  }
  .footer-social:hover { color: var(--text-muted); transform: translateY(-2px); }

  .footer-nav {
    display: flex;
    flex-wrap: wrap;
    gap: 0.25rem 1.25rem;
  }
  @media (min-width: 640px) {
    .footer-nav { flex-direction: column; gap: 0.4rem; text-align: right; }
  }

  .footer-nav-link {
    font-size: 0.825rem;
    color: var(--text-dimmer);
    text-decoration: none;
    transition: color 0.2s ease;
  }
  .footer-nav-link:hover { color: var(--text-muted); }

  .footer-bottom {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    padding-top: 1.5rem;
    border-top: 1px solid var(--border);
  }
  @media (min-width: 640px) {
    .footer-bottom { flex-direction: row; justify-content: space-between; align-items: center; }
  }

  .footer-copy {
    font-size: 0.75rem;
    color: var(--text-dimmer);
    margin: 0;
  }

  .footer-utils {
    display: flex;
    gap: 1rem;
  }

  .footer-util-link {
    font-size: 0.75rem;
    color: var(--text-dimmer);
    text-decoration: none;
    transition: color 0.2s ease;
  }
  .footer-util-link:hover { color: var(--text-muted); }
</style>
