---
import personalData from '../data/personal.json';
---

<section id="home" class="hero-section">
  <div class="container mx-auto px-4 sm:px-6 lg:px-8 max-w-4xl">
    <div class="hero-inner">

      <h1 class="hero-name reveal">{personalData.name}</h1>

      <p class="hero-role reveal" style="transition-delay:0.05s;">{personalData.heroRole}</p>

      <p class="hero-bio reveal" style="transition-delay:0.1s;">{personalData.bio}</p>

      <div class="hero-links reveal" style="transition-delay:0.15s;">
        {personalData.github && (
          <a href={personalData.github} target="_blank" rel="noopener noreferrer" class="hero-icon-link" aria-label="GitHub">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0 0 24 12c0-6.63-5.37-12-12-12z"/>
            </svg>
          </a>
        )}
        {personalData.linkedin && (
          <a href={personalData.linkedin} target="_blank" rel="noopener noreferrer" class="hero-icon-link" aria-label="LinkedIn">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
            </svg>
          </a>
        )}
        {personalData.email && (
          <a href={`mailto:${personalData.email}`} class="hero-icon-link" aria-label="Email">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <rect width="20" height="16" x="2" y="4" rx="2"/>
              <path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/>
            </svg>
          </a>
        )}
      </div>

      <div class="hero-actions reveal" style="transition-delay:0.2s;">
        <a href="#projects" class="btn-primary">View Projects</a>
        <button onclick="window.print()" class="btn-secondary">Download CV</button>
      </div>

    </div>
  </div>
</section>

<style>
  .hero-section {
    min-height: 100vh;
    display: flex;
    align-items: center;
    background: var(--bg);
    padding-top: 4rem;
    padding-bottom: 4rem;
  }

  .hero-inner {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
    max-width: 640px;
  }

  .hero-name {
    font-size: clamp(2.25rem, 5vw, 3.5rem);
    font-weight: 800;
    color: var(--text);
    letter-spacing: -0.03em;
    line-height: 1.1;
    margin: 0;
  }

  .hero-role {
    font-size: 1.05rem;
    color: var(--text-dim);
    font-weight: 400;
    margin: 0;
    line-height: 1.5;
  }

  .hero-bio {
    font-size: 0.95rem;
    color: var(--text-muted);
    line-height: 1.75;
    max-width: 560px;
    margin: 0;
  }

  .hero-links {
    display: flex;
    align-items: center;
    gap: 1rem;
  }

  .hero-icon-link {
    color: var(--text-dimmer);
    display: inline-flex;
    align-items: center;
    transition: color 0.2s ease, transform 0.2s ease;
  }
  .hero-icon-link:hover {
    color: var(--text);
    transform: translateY(-2px);
  }
  .hero-icon-link:focus-visible {
    outline: 2px solid var(--text);
    outline-offset: 3px;
    border-radius: 2px;
  }

  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    margin-top: 0.25rem;
  }
</style>

<script>
  document.querySelectorAll('#home .reveal').forEach((el) => {
    const io = new IntersectionObserver(([entry]) => {
      if (entry.isIntersecting) { el.classList.add('visible'); io.disconnect(); }
    }, { threshold: 0.05 });
    io.observe(el);
  });
</script>
