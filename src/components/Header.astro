---
import personalData from '../data/personal.json';
import menu from '../data/menu.json';
import siteData from '../data/site.json';

const { sections } = menu;

const external = siteData.navExternal
  .map((item) => {
    const value = (personalData as unknown as Record<string, string>)[item.personalKey] ?? '';
    if (!value) return null;
    return {
      label: item.label,
      desc: item.desc,
      url: item.urlTemplate.replace('{value}', value),
    };
  })
  .filter(Boolean) as { label: string; desc: string; url: string }[];
---

<header class="fixed top-0 left-0 right-0 z-50 glass-nav">
  <nav class="container mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-14">
      <a href="/" class="site-logo">
        {personalData.name}
      </a>

      <div class="hidden lg:flex items-center gap-6">
        {sections.map((item) => (
          <a href={item.href} class="nav-link nav-link-sm">{item.shortLabel}</a>
        ))}
      </div>

      <div class="flex items-center gap-2">
        <button
          id="theme-toggle"
          class="theme-btn"
          aria-label="Toggle dark mode"
          title="Toggle dark mode"
        >
          <svg id="theme-icon-sun" class="theme-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="12" cy="12" r="4"/><path d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M6.34 17.66l-1.41 1.41M19.07 4.93l-1.41 1.41"/>
          </svg>
          <svg id="theme-icon-moon" class="theme-icon hidden" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
          </svg>
        </button>
        <a href="#contact" class="cta-btn hidden sm:inline-flex">Contact</a>
        <button id="menu-open-btn" class="hamburger-btn" aria-label="Open menu">
          <span></span><span></span><span></span>
        </button>
      </div>
    </div>

    <!-- Desktop external links bar (no numbers) -->
    <div id="dm-wrapper" class="dm-wrapper">
      <div class="desktop-mega">
        {external.map((link, i) => (
          <a href={link.url} target="_blank" rel="noopener" class="dm-item" style={`--i: ${i};`}>
            <span class="dm-body">
              <span class="dm-label">{link.label}</span>
              <span class="dm-desc">{link.desc}</span>
            </span>
            <svg class="dm-arrow" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 19.5l15-15m0 0H8.25m11.25 0v11.25"/>
            </svg>
          </a>
        ))}
      </div>
    </div>
  </nav>
</header>

<!-- Full-screen overlay menu -->
<div
  id="overlay-menu"
  class="overlay"
  role="dialog"
  aria-modal="true"
  aria-label="Site navigation"
  aria-hidden="true"
>
  <button id="menu-close-btn" class="overlay-close" aria-label="Close menu">
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
      <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/>
    </svg>
  </button>

  <div class="overlay-inner">
    <p class="overlay-eyebrow">Navigate</p>
    <nav class="overlay-nav">
      {sections.map((item, i) => (
        <a href={item.href} class="overlay-link" style={`--i: ${i};`}>
          <span class="overlay-link-body">
            <span class="overlay-link-label">{item.label}</span>
            <span class="overlay-link-desc">{item.desc}</span>
          </span>
          <svg class="overlay-arrow" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 19.5l15-15m0 0H8.25m11.25 0v11.25"/>
          </svg>
        </a>
      ))}
    </nav>

    {external.length > 0 && (
      <div class="overlay-bottom">
        <p class="overlay-bottom-label">External</p>
        {external.map((link) => (
          <a href={link.url} target="_blank" rel="noopener" class="overlay-quick-link">
            {link.label}
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="overlay-ext-icon">
              <path stroke-linecap="round" stroke-linejoin="round" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/>
            </svg>
          </a>
        ))}
      </div>
    )}
  </div>
</div>

<style>
  .site-logo {
    font-size: 0.95rem;
    font-weight: 700;
    color: var(--text);
    text-decoration: none;
    letter-spacing: -0.01em;
    transition: opacity 0.2s ease;
  }
  .site-logo:hover { opacity: 0.7; }

  .nav-link-sm {
    font-size: 0.8rem;
    letter-spacing: 0.03em;
    color: var(--text-dim);
  }
  .nav-link-sm:hover { color: var(--text); }

  .theme-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 32px;
    height: 32px;
    border-radius: 6px;
    border: 1px solid var(--border);
    background: transparent;
    color: var(--text-dim);
    cursor: pointer;
    transition: color 0.2s ease, border-color 0.2s ease, background 0.2s ease;
  }
  .theme-btn:hover {
    color: var(--text);
    border-color: var(--border-hover);
    background: var(--bg-surface);
  }
  .theme-icon { width: 15px; height: 15px; }
  .hidden { display: none !important; }

  .cta-btn {
    align-items: center;
    padding: 0.4rem 0.9rem;
    border-radius: 0.375rem;
    font-size: 0.78rem;
    font-weight: 600;
    border: 1px solid var(--border);
    color: var(--text-muted);
    white-space: nowrap;
    text-decoration: none;
    transition: background 0.2s ease, border-color 0.2s ease, color 0.2s ease;
  }
  .cta-btn:hover {
    background: var(--bg-surface);
    border-color: var(--border-hover);
    color: var(--text);
  }

  .hamburger-btn {
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 4px;
    width: 32px;
    height: 32px;
    padding: 6px;
    background: transparent;
    border: 1px solid var(--border);
    border-radius: 6px;
    cursor: pointer;
    transition: background 0.2s ease, border-color 0.2s ease;
  }
  .hamburger-btn:hover {
    background: var(--bg-surface);
    border-color: var(--border-hover);
  }
  .hamburger-btn span {
    display: block;
    width: 100%;
    height: 1.5px;
    background: var(--text-dim);
    border-radius: 9999px;
  }
  .hamburger-btn span:last-child { width: 65%; }

  /* Desktop external bar */
  .dm-wrapper { display: none; }
  @media (min-width: 1024px) {
    .dm-wrapper {
      display: grid;
      grid-template-rows: 1fr;
      opacity: 1;
      border-top: 1px solid var(--border);
      transition: grid-template-rows 0.45s ease, opacity 0.35s ease, border-top-color 0.35s ease;
    }
    header.scrolled .dm-wrapper {
      grid-template-rows: 0fr;
      opacity: 0;
      border-top-color: transparent;
    }
  }
  .desktop-mega {
    min-height: 0;
    overflow: hidden;
    display: flex;
    margin: 0 -1rem;
  }
  .dm-item {
    flex: 1;
    display: flex;
    align-items: center;
    gap: 0.6rem;
    padding: 0.6rem 1rem;
    border-right: 1px solid var(--border);
    text-decoration: none;
    color: var(--text-dim);
    transition: color 0.2s ease, background 0.2s ease,
      transform 0.4s ease calc(var(--i) * 0.04s),
      opacity 0.3s ease calc(var(--i) * 0.04s);
  }
  header.scrolled .dm-item { transform: translateY(-8px); opacity: 0; }
  .dm-item:last-child { border-right: none; }
  .dm-item:hover { background: var(--bg-surface); color: var(--text); }
  .dm-body { display: flex; flex-direction: column; gap: 0.1rem; flex: 1; min-width: 0; }
  .dm-label { font-size: 0.88rem; font-weight: 600; color: var(--text-muted); white-space: nowrap; transition: color 0.2s ease; }
  .dm-item:hover .dm-label { color: var(--text); }
  .dm-desc { font-size: 0.63rem; color: var(--text-dimmer); white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
  .dm-arrow { width: 0.8rem; height: 0.8rem; color: var(--text-dimmer); flex-shrink: 0; transition: transform 0.25s ease, color 0.2s ease; }
  .dm-item:hover .dm-arrow { color: var(--text-muted); transform: translate(2px, -2px); }

  /* Overlay menu */
  .overlay {
    position: fixed;
    inset: 0;
    z-index: 200;
    background: var(--bg-overlay);
    display: flex;
    flex-direction: column;
    pointer-events: none;
    opacity: 0;
    transition: opacity 0.3s ease;
  }
  .overlay.open {
    opacity: 1;
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    pointer-events: all;
  }
  .overlay-close {
    position: absolute;
    top: 1.25rem;
    right: 1.5rem;
    width: 40px;
    height: 40px;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 50%;
    background: transparent;
    border: 1px solid var(--border);
    color: var(--text-dim);
    cursor: pointer;
    transition: color 0.2s ease, background 0.2s ease;
  }
  .overlay-close svg { width: 18px; height: 18px; }
  .overlay-close:hover { color: var(--text); background: var(--bg-surface); }
  .overlay-inner {
    display: flex;
    flex-direction: column;
    justify-content: center;
    flex: 1;
    padding: 5rem 6vw 3rem;
    max-width: 720px;
  }
  .overlay-eyebrow {
    font-size: 0.65rem;
    font-weight: 700;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--text-dimmer);
    margin-bottom: 2rem;
  }
  .overlay-nav { display: flex; flex-direction: column; gap: 0; }
  .overlay-link {
    display: flex;
    align-items: center;
    gap: 1.5rem;
    padding: 1rem 0;
    border-bottom: 1px solid var(--border);
    text-decoration: none;
    color: var(--text-muted);
    opacity: 0;
    transform: translateY(16px);
    transition:
      opacity 0.4s ease calc(var(--i) * 0.06s),
      transform 0.4s cubic-bezier(0.22, 1, 0.36, 1) calc(var(--i) * 0.06s),
      color 0.2s ease;
  }
  .overlay.open .overlay-link { opacity: 1; transform: translateY(0); }
  .overlay-link:hover { color: var(--text); }
  .overlay-link-body { display: flex; flex-direction: column; gap: 0.15rem; flex: 1; }
  .overlay-link-label {
    font-size: clamp(1.5rem, 4vw, 2.5rem);
    font-weight: 800;
    line-height: 1;
    letter-spacing: -0.03em;
    color: var(--text);
  }
  .overlay-link-desc { font-size: 0.78rem; color: var(--text-dim); }
  .overlay-arrow {
    width: 1.25rem;
    height: 1.25rem;
    color: var(--text-dimmer);
    flex-shrink: 0;
    transition: transform 0.25s ease, color 0.2s ease;
  }
  .overlay-link:hover .overlay-arrow { color: var(--text-muted); transform: translate(3px, -3px); }
  .overlay-bottom {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.5rem 1.25rem;
    padding-top: 1.75rem;
    border-top: 1px solid var(--border);
    margin-top: 0.75rem;
  }
  .overlay-bottom-label {
    font-size: 0.6rem;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--text-dimmer);
    width: 100%;
  }
  .overlay-quick-link {
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    font-size: 0.78rem;
    font-weight: 500;
    color: var(--text-dim);
    text-decoration: none;
    transition: color 0.2s ease;
  }
  .overlay-quick-link:hover { color: var(--text); }
  .overlay-ext-icon { width: 11px; height: 11px; opacity: 0.5; }

  .nav-link.active { color: var(--text); }
  .nav-link.active::after { width: 100%; }

  @media (min-width: 640px) and (max-width: 767px) {
    header .container .gap-3 { gap: 30vw !important; }
  }
  @media (min-width: 1024px) and (max-width: 1279px) {
    header .container .gap-6 { gap: 1rem !important; }
  }
</style>

<script>
  // Overlay menu open/close
  const overlay = document.getElementById('overlay-menu')!;
  const openBtn = document.getElementById('menu-open-btn')!;
  const closeBtn = document.getElementById('menu-close-btn')!;

  function openMenu() {
    overlay.classList.add('open');
    overlay.setAttribute('aria-hidden', 'false');
    document.body.style.overflow = 'hidden';
  }
  function closeMenu() {
    overlay.classList.remove('open');
    overlay.setAttribute('aria-hidden', 'true');
    document.body.style.overflow = '';
  }
  openBtn.addEventListener('click', openMenu);
  closeBtn.addEventListener('click', closeMenu);
  overlay.querySelectorAll('.overlay-link, .overlay-quick-link').forEach((a) => a.addEventListener('click', closeMenu));
  document.addEventListener('keydown', (e) => { if (e.key === 'Escape') closeMenu(); });

  // Scroll: collapse external links bar
  const header = document.querySelector('header')!;
  let ticking = false;
  function onScroll() {
    if (!ticking) {
      requestAnimationFrame(() => {
        if (window.innerWidth >= 1024) {
          header.classList.toggle('scrolled', window.scrollY > 40);
        } else {
          header.classList.remove('scrolled');
        }
        ticking = false;
      });
      ticking = true;
    }
  }
  window.addEventListener('scroll', onScroll, { passive: true });
  window.addEventListener('resize', onScroll, { passive: true });

  // Active nav link tracking
  const sections = document.querySelectorAll('section[id]');
  const navLinks = document.querySelectorAll('.nav-link');
  new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          navLinks.forEach((l) => l.classList.remove('active'));
          document.querySelector(`.nav-link[href="#${entry.target.id}"]`)?.classList.add('active');
        }
      });
    },
    { rootMargin: '-40% 0px -55% 0px' }
  ).observe(sections[0] ?? document.body);
  sections.forEach((s) => {
    new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            navLinks.forEach((l) => l.classList.remove('active'));
            document.querySelector(`.nav-link[href="#${entry.target.id}"]`)?.classList.add('active');
          }
        });
      },
      { rootMargin: '-40% 0px -55% 0px' }
    ).observe(s);
  });

  // Dark mode toggle
  const themeToggle = document.getElementById('theme-toggle')!;
  const iconSun = document.getElementById('theme-icon-sun')!;
  const iconMoon = document.getElementById('theme-icon-moon')!;

  function applyTheme(theme: string) {
    document.documentElement.setAttribute('data-theme', theme);
    localStorage.setItem('theme', theme);
    if (theme === 'dark') {
      iconSun.classList.add('hidden');
      iconMoon.classList.remove('hidden');
    } else {
      iconSun.classList.remove('hidden');
      iconMoon.classList.add('hidden');
    }
  }

  // Sync icon with current theme on load
  applyTheme(document.documentElement.getAttribute('data-theme') || 'light');

  themeToggle.addEventListener('click', () => {
    const current = document.documentElement.getAttribute('data-theme') || 'light';
    applyTheme(current === 'dark' ? 'light' : 'dark');
  });
</script>
