---
import menuData from '../data/menu.json';
import siteData from '../data/site.json';

const sections = menuData.sections;
const current = Astro.url.pathname.replace(/\/+$/, '') || '/';

function isActive(href: string) {
  const target = href.replace(/\/+$/, '') || '/';
  if (target === '/') return current === '/';
  return current === target || current.startsWith(target + '/');
}
---

<header class="site-nav" transition:persist="site-nav">
  <div class="nav-inner">
    <a href="/" class="monogram" aria-label="Home">
      <span class="mono-mark">KU</span>
      <span class="mono-rule" aria-hidden="true"></span>
    </a>

    <nav class="nav-links" aria-label="Primary">
      {sections.map((s) => (
        <a
          href={s.href}
          class:list={["nav-link", { "is-active": isActive(s.href) }]}
          data-href={s.href}
        >
          {s.label}
        </a>
      ))}
    </nav>

    <div class="nav-right">
      <span class="nav-mark" aria-hidden="true">{siteData.shortName}</span>
      <button id="nav-toggle" class="nav-burger" aria-label="Open menu" aria-expanded="false" aria-controls="nav-overlay">
        <span class="burger-bar"></span>
        <span class="burger-bar"></span>
      </button>
    </div>
  </div>
  <div class="nav-hairline" aria-hidden="true"></div>
</header>

<!-- Mobile overlay -->
<div id="nav-overlay" class="nav-overlay" aria-hidden="true" transition:persist="nav-overlay">
  <button id="nav-close" class="nav-close" aria-label="Close menu">
    <span class="x-bar a"></span>
    <span class="x-bar b"></span>
  </button>
  <nav class="overlay-links" aria-label="Primary mobile">
    {sections.map((s, i) => (
      <a href={s.href} class:list={["overlay-link", { "is-active": isActive(s.href) }]}>
        <span class="ol-num">{String(i + 1).padStart(2, '0')}</span>
        <span class="ol-label">{s.label}</span>
      </a>
    ))}
  </nav>
  <div class="overlay-foot">
    <span class="overlay-mono">{siteData.shortName} · {siteData.tagline}</span>
  </div>
</div>

<style>
  .site-nav {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 1000;
    background: var(--bg-nav);
    -webkit-backdrop-filter: blur(14px) saturate(140%);
    backdrop-filter: blur(14px) saturate(140%);
    border-bottom: 1px solid var(--line);
  }

  .nav-inner {
    max-width: 80rem;
    margin: 0 auto;
    padding: 0.65rem 1.25rem;
    display: flex;
    align-items: center;
    gap: 2rem;
  }
  @media (min-width: 768px) {
    .nav-inner { padding: 0.7rem 2rem; }
  }

  .nav-hairline {
    height: 1px;
    background: linear-gradient(90deg, transparent 0%, var(--line-strong) 20%, var(--line-bright) 50%, var(--line-strong) 80%, transparent 100%);
    opacity: 0.55;
  }

  .monogram {
    display: inline-flex;
    align-items: center;
    gap: 0.55rem;
    text-decoration: none;
    flex-shrink: 0;
  }
  .mono-mark {
    font-family: var(--font-display);
    font-size: 0.95rem;
    font-weight: 700;
    letter-spacing: 0.18em;
    color: var(--text);
    text-transform: uppercase;
  }
  .mono-rule {
    width: 18px;
    height: 1px;
    background: var(--line-bright);
  }

  .nav-links {
    display: none;
    align-items: center;
    gap: 2.1rem;
    margin-left: auto;
  }
  @media (min-width: 900px) {
    .nav-links { display: flex; }
  }

  .nav-link {
    position: relative;
    font-family: var(--font-display);
    font-size: 0.7rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.18em;
    color: var(--text-dim);
    text-decoration: none;
    padding: 0.35rem 0;
    transition: color 0.25s var(--ease-shutter);
  }
  .nav-link::after {
    content: "";
    position: absolute;
    left: 0;
    right: 0;
    bottom: -2px;
    height: 1px;
    background: var(--text);
    transform-origin: 0 50%;
    transform: scaleX(0);
    transition: transform 0.35s var(--ease-shutter);
  }
  .nav-link:hover { color: var(--text); }
  .nav-link:hover::after { transform: scaleX(1); }
  .nav-link.is-active { color: var(--text); }
  .nav-link.is-active::after { transform: scaleX(1); }

  .nav-right {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin-left: auto;
  }
  @media (min-width: 900px) {
    .nav-right { margin-left: 0; }
  }

  .nav-mark {
    display: none;
    font-family: var(--font-mono);
    font-size: 0.62rem;
    letter-spacing: 0.22em;
    color: var(--text-dimmer);
    padding: 0.18rem 0.45rem;
    border: 1px solid var(--line);
  }
  @media (min-width: 900px) {
    .nav-mark { display: inline-block; }
  }

  .nav-burger {
    display: inline-flex;
    flex-direction: column;
    justify-content: center;
    gap: 6px;
    width: 32px;
    height: 32px;
    background: transparent;
    border: 1px solid var(--line-strong);
    cursor: pointer;
    padding: 0;
    align-items: center;
  }
  @media (min-width: 900px) {
    .nav-burger { display: none; }
  }
  .burger-bar { display: block; width: 14px; height: 1px; background: var(--text); }

  .nav-overlay {
    position: fixed;
    inset: 0;
    z-index: 1500;
    background: var(--bg-deep);
    background-image:
      radial-gradient(ellipse at top right, rgba(244, 244, 245, 0.04) 0%, transparent 60%),
      radial-gradient(ellipse at bottom left, rgba(244, 244, 245, 0.025) 0%, transparent 50%);
    transform: translateY(-100%);
    transition: transform 0.42s var(--ease-shutter);
    display: flex;
    flex-direction: column;
    padding: 5rem 1.5rem 2rem;
    pointer-events: none;
  }
  .nav-overlay.is-open {
    transform: translateY(0);
    pointer-events: auto;
  }

  .nav-close {
    position: absolute;
    top: 1.25rem;
    right: 1.25rem;
    width: 36px;
    height: 36px;
    background: transparent;
    border: 1px solid var(--line-strong);
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 0;
  }
  .x-bar { position: absolute; width: 16px; height: 1px; background: var(--text); }
  .x-bar.a { transform: rotate(45deg); }
  .x-bar.b { transform: rotate(-45deg); }

  .overlay-links {
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
    margin-top: 2rem;
  }
  .overlay-link {
    display: grid;
    grid-template-columns: 3rem 1fr;
    gap: 0.75rem;
    align-items: baseline;
    padding: 0.45rem 0;
    text-decoration: none;
    border-bottom: 1px solid var(--line);
  }
  .overlay-link:last-child { border-bottom: none; }
  .ol-num {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    letter-spacing: 0.1em;
    color: var(--text-dimmer);
  }
  .ol-label {
    font-family: var(--font-display);
    font-size: clamp(1.6rem, 7vw, 2.4rem);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.02em;
    color: var(--text-dim);
    transition: color 0.25s var(--ease-shutter);
  }
  .overlay-link:hover .ol-label,
  .overlay-link.is-active .ol-label { color: var(--text); }

  .overlay-foot {
    margin-top: auto;
    padding-top: 2rem;
    border-top: 1px solid var(--line);
  }
  .overlay-mono {
    font-family: var(--font-mono);
    font-size: 0.65rem;
    letter-spacing: 0.18em;
    color: var(--text-dimmer);
    text-transform: uppercase;
  }
</style>

<script>
  function wireNav() {
    const toggle = document.getElementById('nav-toggle');
    const close = document.getElementById('nav-close');
    const overlay = document.getElementById('nav-overlay');
    if (!toggle || !overlay) return;

    function setOpen(open: boolean) {
      overlay!.classList.toggle('is-open', open);
      overlay!.setAttribute('aria-hidden', open ? 'false' : 'true');
      toggle!.setAttribute('aria-expanded', open ? 'true' : 'false');
      document.body.style.overflow = open ? 'hidden' : '';
    }

    toggle.onclick = () => setOpen(!overlay.classList.contains('is-open'));
    if (close) close.onclick = () => setOpen(false);

    overlay.querySelectorAll('.overlay-link').forEach((a) => {
      (a as HTMLAnchorElement).onclick = () => setOpen(false);
    });

    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && overlay.classList.contains('is-open')) setOpen(false);
    });
  }

  wireNav();
  document.addEventListener('astro:page-load', wireNav);
</script>
