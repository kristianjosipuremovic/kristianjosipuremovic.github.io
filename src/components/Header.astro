---
import menuData from '../data/menu.json';
import siteData from '../data/site.json';

const sections = menuData.sections;
const current = Astro.url.pathname.replace(/\/+$/, '') || '/';

function isActive(href: string) {
  const target = href.replace(/\/+$/, '') || '/';
  if (target === '/') return current === '/';
  return current === target || current.startsWith(target + '/');
}
---

<header class="site-nav" transition:persist="site-nav">
  <div class="nav-inner">
    <a href="/" class="monogram" aria-label="Home">
      <span class="mono-mark">KU</span>
      <span class="mono-rule" aria-hidden="true"></span>
    </a>

    <nav class="nav-links" aria-label="Primary">
      {sections.map((s) => (
        <a
          href={s.href}
          class:list={["nav-link", { "is-active": isActive(s.href) }]}
          data-href={s.href}
        >
          {s.label}
        </a>
      ))}
    </nav>

    <div class="nav-right">
      <button id="theme-toggle" class="theme-toggle" type="button" aria-label="Switch theme" aria-pressed="false">
        <!-- MOON — shown in light mode (click → dark) -->
        <svg class="ico-moon" viewBox="0 0 16 16" width="16" height="16" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M13.5 10a5 5 0 1 1-7.5-6.5 4.5 4.5 0 0 0 7.5 6.5z"/>
        </svg>
        <!-- SUN — shown in dark mode (click → light) -->
        <svg class="ico-sun" viewBox="0 0 16 16" width="16" height="16" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <circle cx="8" cy="8" r="3"/>
          <line x1="8" y1="1.6" x2="8" y2="3"/>
          <line x1="8" y1="13" x2="8" y2="14.4"/>
          <line x1="1.6" y1="8" x2="3" y2="8"/>
          <line x1="13" y1="8" x2="14.4" y2="8"/>
          <line x1="3.5" y1="3.5" x2="4.5" y2="4.5"/>
          <line x1="11.5" y1="11.5" x2="12.5" y2="12.5"/>
          <line x1="3.5" y1="12.5" x2="4.5" y2="11.5"/>
          <line x1="11.5" y1="4.5" x2="12.5" y2="3.5"/>
        </svg>
      </button>
      <button id="sound-toggle" class="sound-toggle" type="button" aria-label="Sounds off — click to enable" aria-pressed="false">
        <!-- Speaker ON -->
        <svg class="ico-on" viewBox="0 0 16 16" width="16" height="16" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M3 6.2v3.6h2.2L8.4 12V4L5.2 6.2H3z"/>
          <path d="M10.4 5.6c.8.8 1.2 1.5 1.2 2.4s-.4 1.6-1.2 2.4"/>
          <path d="M12.2 4c1.3 1.3 2 2.4 2 4s-.7 2.7-2 4"/>
        </svg>
        <!-- Speaker OFF (X-ed) -->
        <svg class="ico-off" viewBox="0 0 16 16" width="16" height="16" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M3 6.2v3.6h2.2L8.4 12V4L5.2 6.2H3z"/>
          <line x1="10.2" y1="5.6" x2="14.4" y2="10.4"/>
          <line x1="14.4" y1="5.6" x2="10.2" y2="10.4"/>
        </svg>
      </button>
      <button id="nav-toggle" class="nav-burger" aria-label="Open menu" aria-expanded="false" aria-controls="nav-overlay">
        <span class="burger-bar"></span>
        <span class="burger-bar"></span>
      </button>
    </div>
  </div>
  <div class="nav-hairline" aria-hidden="true"></div>
</header>

<!-- Mobile overlay -->
<div id="nav-overlay" class="nav-overlay" aria-hidden="true" transition:persist="nav-overlay">
  <button id="nav-close" class="nav-close" aria-label="Close menu">
    <span class="x-bar a"></span>
    <span class="x-bar b"></span>
  </button>
  <nav class="overlay-links" aria-label="Primary mobile">
    {sections.map((s, i) => (
      <a href={s.href} class:list={["overlay-link", { "is-active": isActive(s.href) }]}>
        <span class="ol-num">{String(i + 1).padStart(2, '0')}</span>
        <span class="ol-label">{s.label}</span>
      </a>
    ))}
  </nav>
  <div class="overlay-foot">
    <span class="overlay-mono">{siteData.shortName} · {siteData.tagline}</span>
  </div>
</div>

<style>
  .site-nav {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 1000;
    background: var(--bg-nav);
    -webkit-backdrop-filter: blur(14px) saturate(140%);
    backdrop-filter: blur(14px) saturate(140%);
    border-bottom: 1px solid var(--line);
  }

  .nav-inner {
    max-width: 80rem;
    margin: 0 auto;
    padding: 0.65rem 1.25rem;
    display: flex;
    align-items: center;
    gap: 2rem;
  }
  @media (min-width: 768px) {
    .nav-inner { padding: 0.7rem 2rem; }
  }

  /* Red Element 1 — Nav line.
     A single 1px ruled red line flush below the nav bar. */
  .nav-hairline {
    height: 1px;
    background: var(--red);
  }

  .monogram {
    display: inline-flex;
    align-items: center;
    gap: 0.55rem;
    text-decoration: none;
    flex-shrink: 0;
  }
  .mono-mark {
    font-family: var(--font-display);
    font-size: 0.95rem;
    font-weight: 700;
    letter-spacing: 0.18em;
    color: var(--text);
    text-transform: uppercase;
  }
  .mono-rule {
    width: 18px;
    height: 1px;
    background: var(--line-bright);
  }

  .nav-links {
    display: none;
    align-items: center;
    gap: 2.1rem;
    margin-left: auto;
  }
  @media (min-width: 900px) {
    .nav-links { display: flex; }
  }

  .nav-link {
    position: relative;
    font-family: var(--font-display);
    font-size: 0.7rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.18em;
    color: var(--text-dim);
    text-decoration: none;
    padding: 0.35rem 0;
    transition: color 0.25s var(--ease-shutter);
  }
  /* Red Element 2 — Active nav indicator.
     2px Soviet red underline that tracks the active page; appears briefly on hover. */
  .nav-link::after {
    content: "";
    position: absolute;
    left: 0;
    right: 0;
    bottom: -2px;
    height: 2px;
    background: var(--red);
    transform-origin: 0 50%;
    transform: scaleX(0);
    transition: transform 0.35s var(--ease-shutter);
  }
  .nav-link:hover { color: var(--text); }
  .nav-link:hover::after { transform: scaleX(1); }
  .nav-link.is-active { color: var(--text); }
  .nav-link.is-active::after { transform: scaleX(1); }

  .nav-right {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin-left: auto;
  }
  @media (min-width: 900px) {
    .nav-right { margin-left: 0; }
  }

  /* Sound toggle — small 16×16 minimal speaker, switches between on/off icons */
  .sound-toggle {
    background: transparent;
    border: none;
    padding: 4px;
    cursor: pointer;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    color: var(--text-dim);
    line-height: 0;
    transition: color 0.2s var(--ease-shutter);
  }
  .sound-toggle:hover,
  .sound-toggle:focus-visible { color: var(--text); }
  .sound-toggle:focus-visible {
    outline: 1px solid var(--line-bright);
    outline-offset: 2px;
  }
  .sound-toggle .ico-on,
  .sound-toggle .ico-off { display: none; }
  .sound-toggle[aria-pressed="true"]  .ico-on  { display: inline-block; }
  .sound-toggle[aria-pressed="false"] .ico-off { display: inline-block; }

  /* Theme toggle — same minimal style as sound toggle.
     Shows the icon of the OPPOSITE mode (click to go there). */
  .theme-toggle {
    background: transparent;
    border: none;
    padding: 4px;
    cursor: pointer;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    color: var(--text-dim);
    line-height: 0;
    transition: color 0.2s var(--ease-shutter);
  }
  .theme-toggle:hover,
  .theme-toggle:focus-visible { color: var(--text); }
  .theme-toggle:focus-visible {
    outline: 1px solid var(--line-bright);
    outline-offset: 2px;
  }
  /* Icon visibility swap driven by <html data-theme>. Lives in global.css
     because the ancestor selector must not be scoped. */

  .nav-burger {
    display: inline-flex;
    flex-direction: column;
    justify-content: center;
    gap: 6px;
    width: 32px;
    height: 32px;
    background: transparent;
    border: 1px solid var(--line-strong);
    cursor: pointer;
    padding: 0;
    align-items: center;
  }
  @media (min-width: 900px) {
    .nav-burger { display: none; }
  }
  .burger-bar { display: block; width: 14px; height: 1px; background: var(--text); }

  .nav-overlay {
    position: fixed;
    inset: 0;
    z-index: 1500;
    background: var(--bg-deep);
    background-image:
      radial-gradient(ellipse at top right, rgba(244, 244, 245, 0.04) 0%, transparent 60%),
      radial-gradient(ellipse at bottom left, rgba(244, 244, 245, 0.025) 0%, transparent 50%);
    transform: translateY(-100%);
    transition: transform 0.42s var(--ease-shutter);
    display: flex;
    flex-direction: column;
    padding: 5rem 1.5rem 2rem;
    pointer-events: none;
  }
  .nav-overlay.is-open {
    transform: translateY(0);
    pointer-events: auto;
  }

  .nav-close {
    position: absolute;
    top: 1.25rem;
    right: 1.25rem;
    width: 36px;
    height: 36px;
    background: transparent;
    border: 1px solid var(--line-strong);
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 0;
  }
  .x-bar { position: absolute; width: 16px; height: 1px; background: var(--text); }
  .x-bar.a { transform: rotate(45deg); }
  .x-bar.b { transform: rotate(-45deg); }

  .overlay-links {
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
    margin-top: 2rem;
  }
  .overlay-link {
    display: grid;
    grid-template-columns: 3rem 1fr;
    gap: 0.75rem;
    align-items: baseline;
    padding: 0.45rem 0;
    text-decoration: none;
    border-bottom: 1px solid var(--line);
  }
  .overlay-link:last-child { border-bottom: none; }
  .ol-num {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    letter-spacing: 0.1em;
    color: var(--text-dimmer);
  }
  .ol-label {
    font-family: var(--font-display);
    font-size: clamp(1.6rem, 7vw, 2.4rem);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.02em;
    color: var(--text-dim);
    transition: color 0.25s var(--ease-shutter);
  }
  .overlay-link:hover .ol-label,
  .overlay-link.is-active .ol-label { color: var(--text); }

  .overlay-foot {
    margin-top: auto;
    padding-top: 2rem;
    border-top: 1px solid var(--line);
  }
  .overlay-mono {
    font-family: var(--font-mono);
    font-size: 0.65rem;
    letter-spacing: 0.18em;
    color: var(--text-dimmer);
    text-transform: uppercase;
  }
</style>

<script>
  function wireNav() {
    const toggle = document.getElementById('nav-toggle');
    const close = document.getElementById('nav-close');
    const overlay = document.getElementById('nav-overlay');
    if (!toggle || !overlay) return;

    function setOpen(open: boolean) {
      overlay!.classList.toggle('is-open', open);
      overlay!.setAttribute('aria-hidden', open ? 'false' : 'true');
      toggle!.setAttribute('aria-expanded', open ? 'true' : 'false');
      document.body.style.overflow = open ? 'hidden' : '';
    }

    toggle.onclick = () => setOpen(!overlay.classList.contains('is-open'));
    if (close) close.onclick = () => setOpen(false);

    overlay.querySelectorAll('.overlay-link').forEach((a) => {
      (a as HTMLAnchorElement).onclick = () => setOpen(false);
    });

    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && overlay.classList.contains('is-open')) setOpen(false);
    });
  }

  function wireThemeToggle() {
    const btn = document.getElementById('theme-toggle');
    if (!btn) return;
    if (btn.dataset.wired === '1') return;
    btn.dataset.wired = '1';

    const html = document.documentElement;
    const reflect = () => {
      const isDark = html.getAttribute('data-theme') === 'dark';
      btn.setAttribute('aria-pressed', isDark ? 'true' : 'false');
      btn.setAttribute(
        'aria-label',
        isDark ? 'Dark theme — switch to light' : 'Light theme — switch to dark'
      );
    };
    reflect();

    btn.addEventListener('click', () => {
      const nextDark = html.getAttribute('data-theme') !== 'dark';
      if (nextDark) {
        html.setAttribute('data-theme', 'dark');
      } else {
        html.removeAttribute('data-theme');
      }
      try {
        localStorage.setItem('kru.theme', nextDark ? 'dark' : 'light');
      } catch { /* ignore */ }
      reflect();
    });
  }

  wireNav();
  wireThemeToggle();
  document.addEventListener('astro:page-load', () => {
    wireNav();
    wireThemeToggle();
  });
</script>
