---
import certificationsData from '../data/certifications.json';

type CertType = 'certification' | 'in-progress' | 'planned';

function badgeClass(type: CertType) {
  if (type === 'in-progress') return 'badge-in-progress';
  if (type === 'planned') return 'badge-planned';
  return 'badge-earned';
}
---

<section id="certifications" class="py-24" style="scroll-margin-top: 80px;">
  <div class="container mx-auto px-4 sm:px-6 lg:px-8 max-w-4xl">

    <div class="mb-12 reveal">
      <p class="section-eyebrow">Credentials</p>
      <h2 class="text-3xl sm:text-4xl font-bold section-title">Certifications</h2>
    </div>

    <div class="cert-grid reveal" style="transition-delay:0.1s;">
      {certificationsData.map((cert, i) => {
        const type = (cert.type ?? 'certification') as CertType;
        return (
          <div class="cert-card" style={`transition-delay: ${i * 0.05}s;`}>
            <div class="cert-header">
              <div class="cert-meta">
                <span class="cert-issuer">{cert.issuer}</span>
                <span class="cert-date">{cert.date}</span>
              </div>
              <span class={`cert-badge ${badgeClass(type)}`}>
                {type === 'in-progress' && <span class="badge-dot" />}
                {cert.status}
              </span>
            </div>
            <h3 class="cert-name">{cert.name}</h3>
            <p class="cert-desc">{cert.description}</p>
            {cert.credentialUrl && (
              <a href={cert.credentialUrl} target="_blank" rel="noopener noreferrer" class="cert-link">
                View Credential
                <svg width="12" height="12" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/>
                </svg>
              </a>
            )}
          </div>
        );
      })}
    </div>
  </div>
</section>

<style>
  .section-eyebrow {
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--text-dimmer);
    margin-bottom: 0.5rem;
  }

  .cert-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1rem;
  }
  @media (min-width: 640px) {
    .cert-grid { grid-template-columns: 1fr 1fr; }
  }

  .cert-card {
    padding: 1.25rem 1.5rem;
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: 6px;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    transition: border-color 0.2s ease;
  }
  .cert-card:hover { border-color: var(--border-hover); }

  .cert-header {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 0.75rem;
  }

  .cert-meta {
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
  }

  .cert-issuer {
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--text-dimmer);
  }

  .cert-date {
    font-size: 0.72rem;
    color: var(--text-dimmer);
  }

  .cert-name {
    font-size: 0.9rem;
    font-weight: 600;
    color: var(--text);
    line-height: 1.4;
    margin: 0;
  }

  .cert-desc {
    font-size: 0.825rem;
    color: var(--text-muted);
    line-height: 1.6;
    margin: 0;
    flex: 1;
  }

  .cert-link {
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    font-size: 0.75rem;
    font-weight: 500;
    color: var(--text-dim);
    text-decoration: none;
    margin-top: 0.25rem;
    transition: color 0.2s ease;
  }
  .cert-link:hover { color: var(--text); }

  /* Badges — grey only */
  .cert-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    padding: 0.2rem 0.55rem;
    border-radius: 9999px;
    font-size: 0.68rem;
    font-weight: 600;
    white-space: nowrap;
    flex-shrink: 0;
    border: 1px solid;
  }

  .badge-earned {
    background: var(--bg-surface);
    color: var(--text-muted);
    border-color: var(--border-hover);
  }

  .badge-in-progress {
    background: var(--bg-surface);
    color: var(--text-dim);
    border-color: var(--border);
  }

  .badge-planned {
    background: var(--bg);
    color: var(--text-dimmer);
    border-color: var(--border);
  }

  .badge-dot {
    display: inline-block;
    width: 5px;
    height: 5px;
    border-radius: 50%;
    background: var(--text-dim);
    flex-shrink: 0;
    animation: dot-pulse 2s ease-in-out infinite;
  }

  @keyframes dot-pulse {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.3; }
  }
</style>

<script>
  document.querySelectorAll('#certifications .reveal').forEach((el) => {
    const io = new IntersectionObserver(([entry]) => {
      if (entry.isIntersecting) { el.classList.add('visible'); io.disconnect(); }
    }, { threshold: 0.05 });
    io.observe(el);
  });
</script>
