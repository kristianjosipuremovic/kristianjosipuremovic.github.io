---
/*
 * Neon Clock — wet, physical hanging neon sign.
 *
 * A small gunmetal beam bolted to the right edge of the page supports a
 * dark housing via two wires. The housing contains three independently-
 * flickering neon tubes (red hours / green minutes / blue seconds) with
 * a tiny "CERIAS RESEARCH NODE" decorator and a WEST LAFAYETTE label.
 * 22 rain streaks fall down the inside of the housing glass with vertical
 * water-streak marks on the frame itself.
 *
 * The clock mechanism (IDs + JS update loop + colon blink) is unchanged.
 * Fixed bottom-right, pointer-events: none, z-index 100.
 */

const STREAK_COUNT = 22;
const streaks = Array.from({ length: STREAK_COUNT }, (_, i) => {
  // Math.random() runs once at build time, fixed per build.
  const x = Math.random() * 96;                 // 0–96 %
  const y = Math.random() * 88;                 // 0–88 %
  const h = 4 + Math.random() * 8;              // 4–12 px
  const opacity = 0.06 + Math.random() * 0.12;  // 0.06–0.18
  const duration = 0.8 + Math.random() * 1.7;   // 0.8–2.5 s
  const delay = Math.random() * 4;              // 0–4 s
  return {
    style:
      `left:${x.toFixed(2)}%;` +
      `top:${y.toFixed(2)}%;` +
      `height:${h.toFixed(1)}px;` +
      `--streak-opacity:${opacity.toFixed(3)};` +
      `animation-duration:${duration.toFixed(2)}s;` +
      `animation-delay:${delay.toFixed(2)}s;`,
  };
});
---

<div class="neon-clock" aria-hidden="true" transition:persist="neon-clock">
  <!-- Gunmetal beam jutting from the right wall -->
  <div class="neon-beam">
    <span class="bolt bolt-1"></span>
    <span class="bolt bolt-2"></span>
  </div>

  <!-- Two wires hanging from the bolts down to the sign -->
  <div class="wires-row">
    <span class="wire wire-1"></span>
    <span class="wire wire-2"></span>
  </div>

  <!-- The sign housing -->
  <div class="neon-frame">
    <!-- The clock — three independent neon tubes plus colons -->
    <div class="neon-time">
      <span id="neon-hours"   class="num num-h">00</span><span class="neon-colon">:</span><span id="neon-minutes" class="num num-m">00</span><span class="neon-colon">:</span><span id="neon-seconds" class="num num-s">00</span>
    </div>

    <div class="neon-sublabel">◈ CERIAS RESEARCH NODE ◈</div>
    <div class="neon-label">West Lafayette, IN</div>

    <!-- Rain streaks on the inside of the sign glass -->
    <div class="rain-overlay">
      {streaks.map((s) => <span class="streak" style={s.style}></span>)}
    </div>
  </div>
</div>

<style>
  .neon-clock {
    position: fixed;
    bottom: 32px;
    right: 0;
    z-index: 100;
    pointer-events: none;
    user-select: none;
    -webkit-user-select: none;
    display: flex;
    flex-direction: column;
    align-items: flex-end;
  }

  /* ── BEAM ── */
  .neon-beam {
    position: relative;
    width: 80px;
    height: 6px;
    background: linear-gradient(to left, #2a2a2a, #1a1a1a);
    box-shadow:
      0 2px 8px rgba(0, 0, 0, 0.8),
      inset 0 1px 0 rgba(255, 255, 255, 0.1);
  }
  .bolt {
    position: absolute;
    top: 1px;
    width: 4px;
    height: 4px;
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.15);
  }
  .bolt-1 { left: 8px; }
  .bolt-2 { left: 22px; }

  /* ── WIRES (hang from the bolts down to the frame) ── */
  .wires-row {
    position: relative;
    width: 80px;     /* same span as the beam — wires hang directly below bolts */
    height: 24px;
  }
  .wire {
    position: absolute;
    top: 0;
    width: 1px;
    height: 24px;
    background: rgba(255, 255, 255, 0.2);
  }
  .wire-1 { left: 10px; }
  .wire-2 { left: 24px; }

  /* ── HOUSING ── */
  .neon-frame {
    position: relative;
    padding: 16px 24px 14px;
    border: 3px solid #333333;
    background-color: rgba(8, 8, 10, 0.92);
    /* Water-streak marks running vertically down the glass.
       Very faint, almost subliminal. */
    background-image: repeating-linear-gradient(
      90deg,
      transparent 0,
      transparent 3px,
      rgba(255, 255, 255, 0.012) 4px,
      transparent 5px,
      transparent 17px,
      rgba(255, 255, 255, 0.008) 18px,
      transparent 19px
    );
    border-radius: 2px;
    box-shadow:
      0 8px 32px rgba(0, 0, 0, 0.9),
      inset 0 0 20px rgba(0, 0, 0, 0.5),
      0 0 30px rgba(0, 255, 100, 0.15),
      0 0 60px rgba(255, 0, 60, 0.08),
      0 0 40px rgba(0, 100, 255, 0.08);
    overflow: hidden; /* contain rain */
    align-self: flex-end;
  }

  /* ── CLOCK ── */
  .neon-time {
    font-family: 'Courier New', monospace;
    font-size: clamp(32px, 4vw, 52px);
    font-weight: 700;
    letter-spacing: 0.05em;
    line-height: 1;
    color: #ffffff;
    position: relative;
    z-index: 1; /* sit above rain */
    text-align: center;
    white-space: nowrap;
  }

  .num {
    display: inline-block;
    will-change: opacity;
  }

  /* Hours — red */
  .num-h {
    color: #ff3355;
    text-shadow:
      0 0 2px  #ffffff,
      0 0 6px  #ff3355,
      0 0 12px #ff3355,
      0 0 24px #ff0033,
      0 0 48px rgba(204, 0, 34, 0.53);
    animation: flicker-red 4.7s linear infinite;
  }
  /* Minutes — green (the dominant tube) */
  .num-m {
    color: #00ff88;
    text-shadow:
      0 0 2px  #ffffff,
      0 0 6px  #00ff88,
      0 0 14px #00ff66,
      0 0 28px #00cc44,
      0 0 56px rgba(0, 170, 51, 0.53);
    animation: flicker-green 3.9s linear infinite;
  }
  /* Seconds — blue */
  .num-s {
    color: #4488ff;
    text-shadow:
      0 0 2px  #ffffff,
      0 0 6px  #4488ff,
      0 0 12px #2266ff,
      0 0 24px #0044cc,
      0 0 48px rgba(0, 34, 153, 0.67);
    animation: flicker-blue 5.3s linear infinite;
  }

  .neon-colon {
    color: #ffffff;
    text-shadow:
      0 0 2px  #ffffff,
      0 0 4px  #ffffff,
      0 0 10px rgba(255, 255, 255, 0.5);
    transition: opacity 0.05s linear;
  }

  @keyframes flicker-red {
    0%, 88%, 100% { opacity: 1; }
    89% { opacity: 0.8; }
    91% { opacity: 1; }
  }
  @keyframes flicker-green {
    0%, 92%, 100% { opacity: 1; }
    93% { opacity: 0.85; }
    95% { opacity: 1; }
    97% { opacity: 0.9; }
  }
  @keyframes flicker-blue {
    0%, 96%, 100% { opacity: 1; }
    97% { opacity: 0.75; }
    98.5% { opacity: 1; }
  }

  /* ── LABELS ── */
  .neon-sublabel {
    position: relative;
    z-index: 1;
    margin-top: 8px;
    font-family: var(--font-mono);
    font-size: 7px;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.2);
    text-align: center;
  }
  .neon-label {
    position: relative;
    z-index: 1;
    margin-top: 2px;
    font-family: var(--font-mono);
    font-size: 8px;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.3);
    text-align: center;
  }

  /* ── RAIN ── */
  .rain-overlay {
    position: absolute;
    inset: 0;
    pointer-events: none;
    overflow: hidden;
    z-index: 2;
  }
  .streak {
    position: absolute;
    width: 1px;
    background: rgba(255, 255, 255, 1);
    transform-origin: 50% 0;
    transform: rotate(-10deg);
    filter: blur(0.4px);
    opacity: 0;
    animation-name: rain-drip;
    animation-timing-function: linear;
    animation-iteration-count: infinite;
  }
  @keyframes rain-drip {
    0%   { transform: translateY(0)    rotate(-10deg); opacity: var(--streak-opacity); }
    80%  { opacity: var(--streak-opacity); }
    100% { transform: translateY(12px) rotate(-10deg); opacity: 0; }
  }

  /* ── MOBILE ── */
  @media (max-width: 640px) {
    .neon-clock { bottom: 16px; }
    .neon-beam,
    .wires-row { display: none; }
    .neon-time { font-size: 22px; }
    .neon-frame { padding: 10px 14px 8px; border-width: 2px; }
    /* Reduce rain streaks to 10 by hiding the rest */
    .streak:nth-child(n+11) { display: none; }
    .neon-sublabel { font-size: 6px; }
    .neon-label { font-size: 7px; }
  }

  /* ── REDUCED MOTION ── */
  @media (prefers-reduced-motion: reduce) {
    .num-h, .num-m, .num-s,
    .streak { animation: none !important; }
    .neon-colon { opacity: 1 !important; }
  }
</style>

<script is:inline>
  (function () {
    var intervalId = null;
    var prefersReduced = false;
    try {
      prefersReduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    } catch (e) { /* ignore */ }

    function pad(n) { return n < 10 ? '0' + n : '' + n; }

    function updateClock() {
      var h = document.getElementById('neon-hours');
      var m = document.getElementById('neon-minutes');
      var s = document.getElementById('neon-seconds');
      if (!h || !m || !s) return;
      var now = new Date();
      h.textContent = pad(now.getHours());
      m.textContent = pad(now.getMinutes());
      s.textContent = pad(now.getSeconds());

      if (!prefersReduced) {
        var colons = document.querySelectorAll('.neon-colon');
        var brightHalf = now.getMilliseconds() < 500;
        for (var i = 0; i < colons.length; i++) {
          colons[i].style.opacity = brightHalf ? '1' : '0.3';
        }
      }
    }

    function start() {
      updateClock();
      if (intervalId) clearInterval(intervalId);
      intervalId = setInterval(updateClock, 100);
    }

    start();
    document.addEventListener('astro:page-load', start);
  })();
</script>
