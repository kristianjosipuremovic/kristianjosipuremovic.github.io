---
const username = 'kristianjosipuremovic';
---

<div class="github-activity reveal">
  <div class="gh-header">
    <svg viewBox="0 0 24 24" fill="currentColor" class="w-4 h-4 gh-icon">
      <path d="M12 0C5.374 0 0 5.373 0 12c0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23A11.509 11.509 0 0 1 12 5.803c1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576C20.566 21.797 24 17.3 24 12c0-6.627-5.373-12-12-12z"/>
    </svg>
    <span class="gh-label">GitHub</span>
    <a href={`https://github.com/${username}`} target="_blank" rel="noopener" class="gh-link">
      @{username} →
    </a>
  </div>

  <!-- Contribution graph via gh-contrib-chart -->
  <div class="gh-contrib-wrapper">
    <img
      src={`https://ghchart.rshah.org/a1a1aa/${username}`}
      alt={`${username}'s GitHub contribution graph`}
      class="gh-contrib-chart"
      loading="lazy"
    />
  </div>
</div>

<style>
  .github-activity {
    margin-top: 2rem;
    padding: 1.25rem;
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: 0.5rem;
  }

  .gh-header {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin-bottom: 1rem;
  }

  .gh-icon { color: var(--text-dimmer); }
  .gh-label {
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--text-dimmer);
  }
  .gh-link {
    margin-left: auto;
    font-size: 0.75rem;
    color: var(--text-dim);
    text-decoration: none;
    transition: color 0.2s ease;
  }
  .gh-link:hover { color: var(--text); }

  .gh-contrib-wrapper {
    overflow-x: auto;
  }
  .gh-contrib-chart {
    width: 100%;
    height: auto;
    min-width: 300px;
    filter: brightness(0.85);
    border-radius: 4px;
  }
</style>
