---
import skillsData from '../data/skills.json';
---

<section id="skills" class="py-24" style="scroll-margin-top: 80px;">
  <div class="container mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-16 reveal">
      <p class="text-sm font-semibold tracking-widest text-highlight uppercase mb-3">
        Tools & technologies
      </p>
      <h2 class="text-3xl sm:text-4xl lg:text-5xl font-bold section-title">Arsenal</h2>
    </div>

    <div class="max-w-5xl mx-auto grid grid-cols-1 md:grid-cols-2 gap-6">
      {
        skillsData.map((category, ci) => (
          <div class="card reveal" style={`transition-delay: ${ci * 0.08}s;`}>
            <h3 class="category-heading">{category.title}</h3>
            <div class="skill-list">
              {category.skills.map((skill: { name: string; desc?: string }) => (
                <div class="skill-row">
                  <span class="skill-prompt">›</span>
                  <div class="skill-body">
                    <span class="skill-name">{skill.name}</span>
                    {skill.desc && <span class="skill-desc">— {skill.desc}</span>}
                  </div>
                </div>
              ))}
            </div>
          </div>
        ))
      }
    </div>
  </div>
</section>

<style>
  .category-heading {
    font-size: 0.65rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--text-dimmer);
    margin-bottom: 1rem;
    padding-bottom: 0.5rem;
    border-bottom: 1px solid var(--border);
  }

  .skill-list {
    display: flex;
    flex-direction: column;
    gap: 0.55rem;
  }

  .skill-row {
    display: flex;
    align-items: baseline;
    gap: 0.5rem;
  }

  .skill-prompt {
    color: var(--text-dimmer);
    font-size: 0.8rem;
    flex-shrink: 0;
    margin-top: 1px;
  }

  .skill-body {
    display: flex;
    flex-wrap: wrap;
    align-items: baseline;
    gap: 0.25rem;
  }

  .skill-name {
    font-size: 0.88rem;
    font-weight: 600;
    color: var(--text-muted);
  }

  .skill-desc {
    font-size: 0.75rem;
    color: var(--text-dim);
    line-height: 1.4;
  }
</style>

<script>
  document.querySelectorAll('#skills .reveal').forEach((el) => {
    const io = new IntersectionObserver(
      ([entry]) => {
        if (entry.isIntersecting) {
          el.classList.add('visible');
          io.disconnect();
        }
      },
      { threshold: 0.1 }
    );
    io.observe(el);
  });
</script>
