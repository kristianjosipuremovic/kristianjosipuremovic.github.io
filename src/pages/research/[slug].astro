---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import researchData from '../../data/research.json';

export function getStaticPaths() {
  return researchData.map((project) => ({
    params: { slug: project.slug },
    props: { project },
  }));
}

const { project } = Astro.props;
const paragraphs = project.description.split('\n\n');
const projectIdx = researchData.findIndex((r) => r.slug === project.slug);
const numeral = String(projectIdx + 1).padStart(2, '0');
---

<Layout title={`${project.title} — Research`} description={project.summary}>
  <div class="web-only">
    <Header />
    <main id="main-content" class="page">
      <div class="container-page">

        <nav class="crumb" aria-label="Breadcrumb">
          <a href="/">~</a>
          <span class="sep">/</span>
          <a href="/research">research</a>
          <span class="sep">/</span>
          <span class="cur">{project.slug}</span>
        </nav>

        <div class="rs-head reveal">
          <span class="sec-numeral">{numeral}</span>
          <span class="status-label is-active">{project.status}</span>
          <span class="rs-updated">Updated · {project.lastUpdated}</span>
        </div>

        <h1 class="rs-title reveal">{project.title}</h1>
        <p class="rs-summary reveal">{project.summary}</p>

        <div class="rs-body reveal" data-pagefind-body>
          {paragraphs.map((para: string) => (
            <p>{para}</p>
          ))}
        </div>

        <div class="rs-back">
          <a href="/research" class="link-bright">← Back to Research</a>
        </div>
      </div>
    </main>
    <Footer />
  </div>
</Layout>

<style>
  .page { padding-top: 7rem; padding-bottom: 6rem; min-height: 100vh; background: var(--bg); }

  .rs-head {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 1rem;
    margin-bottom: 1.25rem;
  }
  .rs-updated {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    letter-spacing: 0.1em;
    color: var(--text-dimmer);
    text-transform: uppercase;
    margin-left: auto;
  }

  /* Red Element 6 — Research status badge on detail page: same red left edge. */
  .rs-head :global(.status-label.is-active) {
    border-color: transparent;
    border-left: 2px solid #CC0000;
    padding-left: 0.7rem;
  }

  .rs-title {
    font-family: var(--font-display);
    font-size: clamp(2rem, 4.5vw, 3.25rem);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: -0.005em;
    line-height: 1.05;
    color: var(--text);
    margin: 0 0 1rem;
    max-width: 36rem;
  }

  .rs-summary {
    font-size: clamp(1rem, 1.6vw, 1.1rem);
    line-height: 1.65;
    color: var(--text-body);
    max-width: 52rem;
    margin: 0 0 2.5rem;
  }

  .rs-body {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    max-width: 52rem;
    margin-top: 2.5rem;
  }
  .rs-body p {
    font-size: 0.95rem;
    line-height: 1.8;
    color: var(--text-body);
    margin: 0;
  }

  .rs-back {
    margin-top: 3.5rem;
    padding-top: 1.5rem;
    border-top: 1px solid var(--line);
  }
</style>
