---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import researchData from '../../data/research.json';

interface ResearchItem {
  slug: string;
  title: string;
  status: string;
  statusColor?: string;
  lastUpdated: string;
  summary: string;
  description: string;
}

const items = researchData as ResearchItem[];
---

<Layout title="Research — Kristian Uremovic" description="Active research projects in binary hardening, mechanistic interpretability, and anomaly detection.">
  <div class="web-only">
    <Header />
    <main id="main-content" class="page">
      <div class="container-page">

        <nav class="crumb" aria-label="Breadcrumb">
          <a href="/">~</a>
          <span class="sep">/</span>
          <span class="cur">research</span>
        </nav>

        <div class="sec-head reveal">
          <span class="sec-numeral">01</span>
          <div>
            <p class="eyebrow">Active research</p>
            <h1 class="sec-title">Research</h1>
            <p class="sec-sub">Active research projects across binary hardening, mechanistic interpretability, and ML anomaly detection.</p>
          </div>
        </div>

        <div class="res-grid">
          {items.map((p, i) => (
            <a href={`/research/${p.slug}`} class:list={["panel-chrome", "res-card", "reveal", { "panel-feature": i === 0, "is-feature": i === 0 }]}>
              <div class="res-head">
                <span class="status-label is-active">{p.status}</span>
                <span class="res-num">{String(i + 1).padStart(2, '0')}</span>
              </div>
              <h2 class="res-title">{p.title}</h2>
              <p class="res-summary">{p.summary}</p>
              <div class="res-foot">
                <span class="res-meta">Updated · {p.lastUpdated}</span>
                <span class="res-arrow" aria-hidden="true">
                  <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.2">
                    <path stroke-linecap="round" d="M5 12h14M13 6l6 6-6 6"/>
                  </svg>
                </span>
              </div>
            </a>
          ))}
        </div>
      </div>
    </main>
    <Footer />
  </div>
</Layout>

<style>
  .page { padding-top: 7rem; padding-bottom: 6rem; min-height: 100vh; background: var(--bg); }

  /* Fragmented composition — Maxim VIII
     1 full-width featured panel + 2 half-width panels */
  .res-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.25rem;
  }
  @media (min-width: 768px) {
    .res-grid {
      grid-template-columns: 1fr 1fr;
    }
    .res-grid > :nth-child(1) { grid-column: 1 / -1; }
  }

  .res-card {
    padding: 1.75rem 1.85rem 1.85rem;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    min-height: 220px;
    color: var(--text);
  }
  .res-card.is-feature { min-height: 260px; }

  .res-head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
  }
  .res-num {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    letter-spacing: 0.18em;
    color: var(--text-dimmer);
  }
  .res-title {
    font-family: var(--font-display);
    font-size: clamp(1.25rem, 2vw, 1.7rem);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.02em;
    color: var(--text);
    line-height: 1.1;
    margin: 0.25rem 0 0;
  }
  .res-card.is-feature .res-title {
    font-size: clamp(1.5rem, 3vw, 2.1rem);
  }
  .res-summary {
    font-size: 0.86rem;
    line-height: 1.65;
    color: var(--text-body);
    margin: 0.4rem 0 0;
    flex: 1;
    max-width: 52rem;
  }
  .res-foot {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    margin-top: 1rem;
    padding-top: 1rem;
    border-top: 1px solid var(--line);
  }
  .res-meta {
    font-family: var(--font-mono);
    font-size: 0.65rem;
    letter-spacing: 0.12em;
    color: var(--text-dimmer);
    text-transform: uppercase;
  }
  .res-arrow {
    color: var(--text-dim);
    transition: transform 0.3s var(--ease-shutter), color 0.2s var(--ease-shutter);
  }
  .res-card:hover .res-arrow { transform: translate(3px, -3px); color: var(--text); }
</style>
