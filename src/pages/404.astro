---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="404 — Not Found" description="Page not found.">
  <div class="web-only">
    <Header />
    <main id="main-content" class="page">
      <div class="container-page narrow">

        <div class="four-wrap">
          <p class="four-status">ERR · 404</p>
          <h1 class="four-code">404</h1>
          <p class="four-en">Page not found.</p>

          <div class="four-actions">
            <a href="/" class="btn-primary">Return Home</a>
            <a href="/blog" class="btn-secondary">Browse Writeups</a>
          </div>
        </div>

      </div>
    </main>
    <Footer />
  </div>
</Layout>

<style>
  .page { padding-top: 8rem; padding-bottom: 8rem; min-height: 100vh; background: var(--bg); display: flex; align-items: center; }
  .container-page.narrow { max-width: 50rem; }

  .four-wrap {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 1.25rem;
  }

  .four-status {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    letter-spacing: 0.22em;
    color: var(--text-dimmer);
    text-transform: uppercase;
    padding: 0.2rem 0.5rem;
    border: 1px solid var(--line);
    margin: 0;
  }

  .four-code {
    font-family: var(--font-display);
    font-size: clamp(5rem, 18vw, 12rem);
    font-weight: 700;
    line-height: 0.85;
    letter-spacing: -0.04em;
    color: var(--text);
    margin: 0.5rem 0 0;
  }

  .four-en {
    font-family: var(--font-display);
    font-size: 1rem;
    text-transform: uppercase;
    letter-spacing: 0.18em;
    color: var(--text-body);
    margin: 0;
  }

  .four-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.85rem;
    margin-top: 1rem;
  }
</style>
