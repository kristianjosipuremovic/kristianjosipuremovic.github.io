---
import Layout from '../layouts/Layout.astro';
const requestedPath = '/page/you/requested';
---

<Layout title="404 — Not Found" description="Page not found.">
  <div class="terminal-404">
    <div class="term-window">
      <div class="term-titlebar">
        <span class="term-dot red"></span>
        <span class="term-dot yellow"></span>
        <span class="term-dot green"></span>
        <span class="term-filename">bash — 80×24</span>
      </div>
      <div class="term-body">
        <div class="term-line">
          <span class="prompt">kristian@portfolio</span><span class="prompt-sep">:</span><span class="prompt-dir">~</span><span class="prompt-dollar">$</span>
          <span class="cmd"> cat {Astro.url.pathname}</span>
        </div>
        <div class="term-line output">cat: {Astro.url.pathname}: No such file or directory</div>
        <div class="term-line empty">&nbsp;</div>
        <div class="term-line">
          <span class="prompt">kristian@portfolio</span><span class="prompt-sep">:</span><span class="prompt-dir">~</span><span class="prompt-dollar">$</span>
          <span class="cmd"> find / -name "$(basename '{Astro.url.pathname}')" 2&gt;/dev/null</span>
        </div>
        <div class="term-line output dim">[no results]</div>
        <div class="term-line empty">&nbsp;</div>
        <div class="term-line">
          <span class="prompt">kristian@portfolio</span><span class="prompt-sep">:</span><span class="prompt-dir">~</span><span class="prompt-dollar">$</span>
          <span class="cursor-blink">_</span>
        </div>
      </div>
    </div>

    <div class="four-oh-four-actions">
      <p class="four-oh-four-msg">This page doesn't exist.</p>
      <a href="/" class="home-link">
        <code>cd ~</code> — go home
      </a>
      <a href="/blog" class="home-link secondary">
        <code>ls ~/blog</code> — browse the blog
      </a>
    </div>
  </div>
</Layout>

<style>
  .terminal-404 {
    min-height: 100vh;
    background: var(--bg);
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 2rem 1rem;
    gap: 2rem;
  }

  .term-window {
    width: 100%;
    max-width: 600px;
    border: 1px solid var(--border);
    border-radius: 0.5rem;
    overflow: hidden;
    box-shadow: 0 8px 40px rgba(0,0,0,0.5);
  }

  .term-titlebar {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.5rem 0.75rem;
    background: rgba(24,24,27,0.9);
    border-bottom: 1px solid var(--border);
  }
  .term-dot {
    width: 10px; height: 10px; border-radius: 50%;
    background: #3f3f46;
  }
  .term-dot.red { background: #ef4444; }
  .term-dot.yellow { background: #eab308; }
  .term-dot.green { background: #22c55e; }
  .term-filename {
    font-size: 0.68rem;
    color: var(--text-dimmer);
    margin-left: auto;
  }

  .term-body {
    background: #0d0d0f;
    padding: 1.25rem 1.5rem;
    min-height: 200px;
    font-size: 0.85rem;
    line-height: 1.8;
  }

  .term-line { display: flex; align-items: baseline; flex-wrap: wrap; gap: 0; }
  .term-line.output { color: var(--text-muted); padding-left: 0; }
  .term-line.output.dim { color: var(--text-dimmer); }
  .term-line.empty { height: 1.8em; }

  .prompt { color: #86efac; font-weight: 700; }
  .prompt-sep { color: var(--text-dimmer); }
  .prompt-dir { color: #93c5fd; }
  .prompt-dollar { color: var(--text-muted); margin-right: 0.25rem; }
  .cmd { color: var(--text); }

  .four-oh-four-actions {
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.75rem;
  }
  .four-oh-four-msg {
    font-size: 0.85rem;
    color: var(--text-dim);
    margin-bottom: 0.25rem;
  }
  .home-link {
    font-size: 0.9rem;
    color: var(--text-muted);
    text-decoration: none;
    padding: 0.5rem 1.25rem;
    border: 1px solid var(--border);
    border-radius: 0.375rem;
    transition: border-color 0.2s ease, color 0.2s ease;
  }
  .home-link:hover { border-color: var(--border-hover); color: var(--text); }
  .home-link.secondary { font-size: 0.8rem; color: var(--text-dim); }
  .home-link code { color: var(--text); }
</style>
