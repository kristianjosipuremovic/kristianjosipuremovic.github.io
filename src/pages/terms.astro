---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import personalData from '../data/personal.json';

const currentYear = new Date().getFullYear();
---

<Layout title={`Terms — ${personalData.name}`} description="Terms of service.">
  <div class="web-only">
    <Header />
    <main id="main-content" class="page">
      <div class="container-page narrow">

        <nav class="crumb" aria-label="Breadcrumb">
          <a href="/">~</a>
          <span class="sep">/</span>
          <span class="cur">terms</span>
        </nav>

        <div class="sec-head reveal">
          <span class="sec-numeral">01</span>
          <div>
            <p class="eyebrow">Legal</p>
            <h1 class="sec-title">Terms</h1>
            <p class="sec-sub">Last updated: January {currentYear}.</p>
          </div>
        </div>

        <div class="prose reveal">
          <h2>1. Acceptance</h2>
          <p>By accessing this website, you accept these Terms of Service. If you do not agree, please do not use this site.</p>

          <h2>2. Use</h2>
          <p>This is a personal portfolio. You may view and share content for informational, non-commercial purposes. You may not reproduce, redistribute, or commercially exploit any content without prior written permission.</p>

          <h2>3. Intellectual Property</h2>
          <p>All content on this site — text, code samples, images, and design — is the property of {personalData.name} unless otherwise noted. Linked open-source projects are governed by their respective licenses.</p>

          <h2>4. Contact Form</h2>
          <p>Submissions are used solely to respond to your inquiry. By submitting the form you agree to be contacted at the email address you provide.</p>

          <h2>5. External Links</h2>
          <p>This site may contain links to external websites. These are provided for convenience only; no responsibility is accepted for external content.</p>

          <h2>6. Limitation of Liability</h2>
          <p>This site is provided "as is" without representation or warranty. No liability arises from use of or reliance on its contents.</p>

          <h2>7. Changes</h2>
          <p>These terms may be updated at any time. Continued use of the site constitutes acceptance of any revised terms.</p>

          <h2>8. Contact</h2>
          <p>Questions? <a href={`mailto:${personalData.email}`} class="link-bright">{personalData.email}</a></p>
        </div>
      </div>
    </main>
    <Footer />
  </div>
</Layout>

<style>
  .page { padding-top: 7rem; padding-bottom: 6rem; min-height: 100vh; background: var(--bg); }
  .container-page.narrow { max-width: 50rem; }

  .prose h2 {
    font-family: var(--font-display);
    font-size: 0.85rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.16em;
    color: var(--text);
    margin: 2.5rem 0 0.85rem;
  }
  .prose p {
    color: var(--text-body);
    line-height: 1.8;
    font-size: 0.92rem;
    margin-bottom: 1rem;
  }
</style>
