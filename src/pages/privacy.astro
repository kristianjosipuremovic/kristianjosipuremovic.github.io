---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import personalData from '../data/personal.json';

const currentYear = new Date().getFullYear();
---

<Layout title={`Privacy — ${personalData.name}`} description="Privacy policy.">
  <div class="web-only">
    <Header />
    <main id="main-content" class="page">
      <div class="container-page narrow">

        <nav class="crumb" aria-label="Breadcrumb">
          <a href="/">~</a>
          <span class="sep">/</span>
          <span class="cur">privacy</span>
        </nav>

        <div class="sec-head reveal">
          <span class="sec-numeral">01</span>
          <div>
            <p class="eyebrow">Legal</p>
            <h1 class="sec-title">Privacy</h1>
            <p class="sec-sub">Last updated: January {currentYear}.</p>
          </div>
        </div>

        <div class="prose reveal">
          <h2>1. Information We Collect</h2>
          <p>This is a static portfolio website. We collect only information you voluntarily provide through the contact form: your name, email address, and message content. We do not use cookies, tracking pixels, or analytics scripts. We do not collect IP addresses or browsing behaviour.</p>

          <h2>2. How We Use Your Information</h2>
          <p>Information submitted via the contact form is used solely to respond to your inquiry. Contact form submissions are processed by <a href="https://web3forms.com" target="_blank" rel="noopener" class="link-bright">Web3Forms</a> — their <a href="https://web3forms.com/privacy" target="_blank" rel="noopener" class="link-bright">privacy policy</a> governs that data.</p>

          <h2>3. Third-Party Services</h2>
          <p>This site loads resources from the following third-party services:</p>
          <ul>
            <li><strong>Google Fonts</strong> — typography (Inter, Space Grotesk).</li>
            <li><strong>Iconify</strong> — icon glyphs loaded on demand.</li>
            <li><strong>Web3Forms</strong> — contact form submission endpoint.</li>
          </ul>
          <p>Each of these services may log your IP address as part of normal server operation. Review their respective privacy policies for details.</p>

          <h2>4. Data Retention</h2>
          <p>We do not store any personal data on our own servers. Contact form data is retained by Web3Forms per their policy.</p>

          <h2>5. Your Rights</h2>
          <p>You may request deletion of any contact form submission by emailing <a href={`mailto:${personalData.email}`} class="link-bright">{personalData.email}</a>.</p>

          <h2>6. Changes</h2>
          <p>This policy may be updated periodically. The date at the top reflects the most recent revision.</p>
        </div>
      </div>
    </main>
    <Footer />
  </div>
</Layout>

<style>
  .page { padding-top: 7rem; padding-bottom: 6rem; min-height: 100vh; background: var(--bg); }
  .container-page.narrow { max-width: 50rem; }

  .prose h2 {
    font-family: var(--font-display);
    font-size: 0.85rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.16em;
    color: var(--text);
    margin: 2.5rem 0 0.85rem;
  }
  .prose p, .prose li {
    color: var(--text-body);
    line-height: 1.8;
    font-size: 0.92rem;
  }
  .prose p { margin-bottom: 1rem; }
  .prose ul { margin: 0 0 1rem 1.25rem; }
  .prose li { margin-bottom: 0.4rem; }
  .prose strong { color: var(--text); font-weight: 600; }
</style>
