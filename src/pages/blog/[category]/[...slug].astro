---
import Layout from '../../../layouts/Layout.astro';
import Header from '../../../components/Header.astro';
import Footer from '../../../components/Footer.astro';
import { getCollection, render, type CollectionEntry } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map((post) => {
    const parts = post.id.split('/');
    const slug = parts[parts.length - 1];
    const category = post.data.category;
    return {
      params: { category, slug },
      props: { post },
    };
  });
}

type Props = { post: CollectionEntry<'blog'> };
const { post } = Astro.props;
const { Content, headings } = await render(post);

const wordCount = (post.body ?? '').split(/\s+/).length;
const readingTime = Math.max(1, Math.ceil(wordCount / 200));

const category = post.data.category;
const categoryLabels: Record<string, string> = {
  'research-writeups': 'Research Writeups',
  'ctf-writeups':      'CTFs',
  'home-labs':         'Home Labs',
  'general':           'General',
};
const categoryLabel = categoryLabels[category] ?? category;

let seriesPosts: typeof post[] = [];
if (post.data.series) {
  const all = await getCollection('blog');
  seriesPosts = all
    .filter((p) => p.data.series === post.data.series)
    .sort((a, b) => (a.data.seriesPart ?? 0) - (b.data.seriesPart ?? 0));
}

const tocHeadings = headings.filter((h) => h.depth <= 3 && h.slug !== 'footnote-label');
---

<Layout title={`${post.data.title} — Kristian Uremovic`} description={post.data.description}>
  <div class="web-only">
    <Header />

    <!-- Reading progress -->
    <div id="reading-progress" aria-hidden="true"></div>

    <main id="main-content" class="post-layout">

      <article class="post-main">
        <div class="container-page narrow">

          <nav class="crumb" aria-label="Breadcrumb">
            <a href="/">~</a>
            <span class="sep">/</span>
            <a href="/blog">writeups</a>
            <span class="sep">/</span>
            <a href={`/blog/${category}`}>{category}</a>
            <span class="sep">/</span>
            <span class="cur">{post.id.split('/').pop()}</span>
          </nav>

          <header class="post-head reveal">
            <p class="post-eyebrow">
              <a href={`/blog/${category}`} class="post-eyebrow-link">{categoryLabel}</a>
            </p>
            <h1 class="post-title">{post.data.title}</h1>
            <p class="post-desc">{post.data.description}</p>

            <table class="hair-table post-meta-table">
              <tbody>
                <tr>
                  <th>Date</th>
                  <td>{post.data.date.toISOString().split('T')[0]}</td>
                </tr>
                <tr>
                  <th>Reading</th>
                  <td>{readingTime} min · {wordCount} words</td>
                </tr>
                <tr>
                  <th>Category</th>
                  <td>{categoryLabel}</td>
                </tr>
              </tbody>
            </table>

            {post.data.series && seriesPosts.length > 0 && (
              <aside class="series-indicator">
                <span class="series-mono">Series</span>
                <span class="series-name">{post.data.series}</span>
                <span class="series-parts">
                  {seriesPosts.map((sp) => {
                    const spSlug = sp.id.split('/').pop()!;
                    const isCurrent = sp.id === post.id;
                    return (
                      <a
                        href={isCurrent ? '#' : `/blog/${sp.data.category}/${spSlug}`}
                        class:list={['series-part-chip', { current: isCurrent }]}
                      >
                        {String(sp.data.seriesPart).padStart(2, '0')}
                      </a>
                    );
                  })}
                </span>
              </aside>
            )}
          </header>

          <div class="prose-content reveal" data-pagefind-body>
            <Content />
          </div>

          {post.data.series && seriesPosts.length > 1 && (
            <div class="series-nav">
              {(() => {
                const prev = seriesPosts.find((s) => (s.data.seriesPart ?? 0) === (post.data.seriesPart ?? 0) - 1);
                return prev ? (
                  <a href={`/blog/${prev.data.category}/${prev.id.split('/').pop()}`} class="panel-chrome series-nav-link prev">
                    <span class="nav-dir">← Previous</span>
                    <span class="nav-title">Part {prev.data.seriesPart} · {prev.data.title}</span>
                  </a>
                ) : null;
              })()}
              {(() => {
                const next = seriesPosts.find((s) => (s.data.seriesPart ?? 0) === (post.data.seriesPart ?? 0) + 1);
                return next ? (
                  <a href={`/blog/${next.data.category}/${next.id.split('/').pop()}`} class="panel-chrome series-nav-link next">
                    <span class="nav-dir">Next →</span>
                    <span class="nav-title">Part {next.data.seriesPart} · {next.data.title}</span>
                  </a>
                ) : null;
              })()}
            </div>
          )}

          <div class="post-back">
            <a href={`/blog/${category}`} class="link-bright">← Back to {categoryLabel}</a>
          </div>
        </div>
      </article>

      {tocHeadings.length > 1 && (
        <aside class="toc-sidebar" aria-label="Table of contents">
          <div class="toc-inner">
            <p class="toc-label">On this page</p>
            <nav>
              {tocHeadings.map((h) => (
                <a href={`#${h.slug}`} class:list={['toc-link', `depth-${h.depth}`]} data-slug={h.slug}>
                  {h.text}
                </a>
              ))}
            </nav>
          </div>
        </aside>
      )}
    </main>

    <button id="back-to-top" aria-label="Back to top">↑</button>

    <Footer />
  </div>
</Layout>

<style is:global>
  /* Reading progress bar */
  #reading-progress {
    position: fixed;
    top: 0;
    left: 0;
    height: 1px;
    background: var(--line-bright);
    width: 0%;
    z-index: 999;
    transition: width 0.1s linear;
  }

  /* Prose */
  .prose-content {
    color: var(--text-body);
    line-height: 1.85;
    font-size: 0.965rem;
    font-family: var(--font-body);
  }
  .prose-content h1,
  .prose-content h2,
  .prose-content h3,
  .prose-content h4 {
    font-family: var(--font-display);
    color: var(--text);
    font-weight: 600;
    margin-top: 2.5rem;
    margin-bottom: 1rem;
    line-height: 1.25;
    scroll-margin-top: 5rem;
    letter-spacing: 0.01em;
  }
  .prose-content h1 { font-size: 1.6rem; text-transform: uppercase; letter-spacing: 0.04em; }
  .prose-content h2 {
    font-size: 1.2rem;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    border-bottom: 1px solid var(--line);
    padding-bottom: 0.55rem;
  }
  .prose-content h3 {
    font-size: 1rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }
  .prose-content h4 { font-size: 0.95rem; }
  .prose-content p { margin-bottom: 1.25rem; }
  .prose-content a {
    color: var(--text);
    text-decoration: none;
    border-bottom: 1px solid var(--line-strong);
    transition: border-color 0.2s ease, color 0.2s ease;
  }
  .prose-content a:hover { color: #ffffff; border-bottom-color: var(--line-bright); }
  .prose-content strong { color: var(--text); font-weight: 600; }
  .prose-content em { color: var(--text-body); font-style: italic; }

  .prose-content ul,
  .prose-content ol { margin: 1rem 0 1.4rem 1.5rem; }
  .prose-content li { margin-bottom: 0.45rem; }
  .prose-content blockquote {
    border-left: 1px solid var(--line-bright);
    padding: 0.15rem 0 0.15rem 1.25rem;
    margin: 1.75rem 0;
    color: var(--text-dim);
    font-style: italic;
  }
  .prose-content hr {
    border: none;
    height: 1px;
    background: var(--line);
    margin: 2.5rem 0;
  }
  .prose-content table {
    width: 100%;
    border-collapse: collapse;
    margin: 1.5rem 0;
    font-size: 0.85rem;
  }
  .prose-content th {
    color: var(--text);
    padding: 0.55rem 0.75rem;
    text-align: left;
    border-bottom: 1px solid var(--line-strong);
    font-family: var(--font-display);
    font-size: 0.7rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
  }
  .prose-content td {
    padding: 0.55rem 0.75rem;
    border-bottom: 1px solid var(--line);
    color: var(--text-body);
  }

  /* Code blocks: graphite slab, silver hairline */
  .prose-content pre {
    background: #08080a !important;
    border: 1px solid var(--line-strong);
    padding: 0 !important;
    margin: 1.75rem 0;
    overflow: hidden;
    position: relative;
    clip-path: polygon(0 0, calc(100% - 10px) 0, 100% 10px, 100% 100%, 0 100%);
  }
  .prose-content pre code {
    display: block;
    padding: 1.1rem 1.35rem;
    overflow-x: auto;
    font-size: 0.815rem;
    line-height: 1.7;
    background: transparent !important;
    color: var(--text-body);
    font-family: var(--font-mono);
  }
  .prose-content pre::before {
    content: 'CODE';
    display: block;
    padding: 0.5rem 1rem;
    background: rgba(244, 244, 245, 0.04);
    border-bottom: 1px solid var(--line);
    font-family: var(--font-display);
    font-size: 0.6rem;
    letter-spacing: 0.22em;
    color: var(--text-dimmer);
    font-weight: 600;
  }
  .prose-content :not(pre) > code {
    background: rgba(244, 244, 245, 0.06);
    border: 1px solid var(--line-strong);
    padding: 0.1rem 0.4rem;
    font-size: 0.85em;
    color: var(--text);
    font-family: var(--font-mono);
  }

  /* Footnotes / sidenotes */
  .sidenote {
    display: none;
    font-size: 0.78rem;
    line-height: 1.65;
    color: var(--text-dim);
    background: rgba(244, 244, 245, 0.03);
    border: 1px solid var(--line);
    padding: 0.5rem 0.75rem;
    margin: 0.5rem 0 0.75rem;
    max-width: 100%;
  }
  .sidenote.open { display: block; }
  .prose-content sup { cursor: pointer; }
  .sidenote-num {
    font-size: 0.6rem;
    font-weight: 700;
    color: var(--text-dimmer);
    vertical-align: super;
    margin-right: 0.2rem;
  }

  @media (min-width: 1400px) {
    .sidenote {
      display: block;
      float: right;
      clear: right;
      width: 11rem;
      margin-right: -12.5rem;
      margin-left: 0.5rem;
      margin-top: 0.2rem;
      padding: 0 0 0 0.75rem;
      background: transparent;
      border: none;
      border-left: 1px solid var(--line-strong);
      font-size: 0.7rem;
      line-height: 1.6;
      color: var(--text-dim);
    }
    .prose-content { overflow: visible; }
  }

  .prose-content .footnotes { display: none; }
</style>

<style>
  .post-layout {
    display: flex;
    position: relative;
    padding-top: 6rem;
    padding-bottom: 6rem;
    background: var(--bg);
    min-height: 100vh;
  }
  .post-main { flex: 1; min-width: 0; }
  .container-page.narrow { max-width: 50rem; }

  .post-head {
    margin: 2rem 0 2rem;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }
  .post-eyebrow {
    font-family: var(--font-display);
    font-size: 0.68rem;
    text-transform: uppercase;
    letter-spacing: 0.22em;
    color: var(--text-dim);
    margin: 0;
  }
  .post-eyebrow-link { color: inherit; text-decoration: none; }
  .post-eyebrow-link:hover { color: var(--text); }

  .post-title {
    font-family: var(--font-display);
    font-size: clamp(1.9rem, 4.5vw, 2.9rem);
    font-weight: 700;
    color: var(--text);
    line-height: 1.1;
    letter-spacing: -0.01em;
    margin: 0;
  }
  .post-desc {
    font-size: 1rem;
    line-height: 1.6;
    color: var(--text-body);
    margin: 0;
    max-width: 42rem;
  }

  .post-meta-table { margin-top: 1.25rem; max-width: 36rem; }
  .post-meta-table th { width: 9rem; }

  .series-indicator {
    margin-top: 1.5rem;
    padding: 0.85rem 1.1rem;
    border: 1px solid var(--line-strong);
    display: flex;
    align-items: center;
    gap: 1rem;
    flex-wrap: wrap;
    clip-path: polygon(0 0, calc(100% - 10px) 0, 100% 10px, 100% 100%, 0 100%);
  }
  .series-mono {
    font-family: var(--font-mono);
    font-size: 0.62rem;
    letter-spacing: 0.22em;
    color: var(--text-dimmer);
    text-transform: uppercase;
  }
  .series-name {
    font-family: var(--font-display);
    font-size: 0.78rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--text);
  }
  .series-parts { display: flex; gap: 0.4rem; flex-wrap: wrap; margin-left: auto; }
  .series-part-chip {
    font-family: var(--font-mono);
    font-size: 0.65rem;
    color: var(--text-dim);
    padding: 0.2rem 0.45rem;
    border: 1px solid var(--line-strong);
    text-decoration: none;
    letter-spacing: 0.1em;
    transition: color 0.2s ease, border-color 0.2s ease;
  }
  .series-part-chip:hover { color: var(--text); border-color: var(--line-bright); }
  .series-part-chip.current { background: var(--text); color: var(--bg); border-color: var(--text); cursor: default; }

  .series-nav {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1rem;
    margin-top: 3rem;
    padding-top: 2rem;
    border-top: 1px solid var(--line);
  }
  @media (min-width: 640px) {
    .series-nav { grid-template-columns: 1fr 1fr; }
  }
  .series-nav-link {
    padding: 1rem 1.25rem;
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
    text-decoration: none;
  }
  .series-nav-link.next { text-align: right; align-items: flex-end; }
  .nav-dir {
    font-family: var(--font-display);
    font-size: 0.6rem;
    text-transform: uppercase;
    letter-spacing: 0.22em;
    color: var(--text-dimmer);
  }
  .nav-title {
    font-size: 0.85rem;
    color: var(--text-body);
    line-height: 1.4;
  }
  .series-nav-link:hover .nav-title { color: var(--text); }

  .post-back {
    margin-top: 3rem;
    padding-top: 1.5rem;
    border-top: 1px solid var(--line);
  }

  /* TOC */
  .toc-sidebar {
    display: none;
    width: 240px;
    flex-shrink: 0;
    padding: 4rem 1.25rem 0;
  }
  @media (min-width: 1280px) {
    .toc-sidebar { display: block; }
  }
  .toc-inner {
    position: sticky;
    top: 5rem;
    max-height: calc(100vh - 8rem);
    overflow-y: auto;
    border-left: 1px solid var(--line);
    padding-left: 1.25rem;
  }
  .toc-label {
    font-family: var(--font-display);
    font-size: 0.6rem;
    font-weight: 600;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--text-dimmer);
    margin-bottom: 1rem;
  }
  .toc-link {
    display: block;
    font-size: 0.78rem;
    color: var(--text-dimmer);
    text-decoration: none;
    padding: 0.25rem 0;
    transition: color 0.2s ease, padding-left 0.2s ease;
    line-height: 1.4;
  }
  .toc-link.depth-3 { padding-left: 0.85rem; font-size: 0.72rem; }
  .toc-link:hover { color: var(--text-body); }
  .toc-link.active { color: var(--text); }

  #back-to-top {
    position: fixed;
    bottom: 1.75rem;
    right: 1.75rem;
    width: 40px;
    height: 40px;
    background: var(--bg-elev-1);
    border: 1px solid var(--line-strong);
    color: var(--text-dim);
    font-family: var(--font-mono);
    font-size: 1rem;
    cursor: pointer;
    opacity: 0;
    transform: translateY(10px);
    transition: opacity 0.3s var(--ease-shutter), transform 0.3s var(--ease-shutter), color 0.2s ease;
    z-index: 50;
    clip-path: polygon(0 0, calc(100% - 6px) 0, 100% 6px, 100% 100%, 0 100%);
  }
  #back-to-top.visible { opacity: 1; transform: translateY(0); }
  #back-to-top:hover { color: var(--text); border-color: var(--line-bright); }
</style>

<script>
  function wirePostPage() {
    // Reading progress
    const bar = document.getElementById('reading-progress');
    const content = document.querySelector('.prose-content');
    function updateProgress() {
      if (!bar || !content) return;
      const rect = (content as HTMLElement).getBoundingClientRect();
      const total = (content as HTMLElement).clientHeight;
      const scrolled = Math.min(Math.max(-rect.top, 0), total);
      (bar as HTMLElement).style.width = `${(scrolled / total) * 100}%`;
    }
    window.addEventListener('scroll', updateProgress, { passive: true });
    updateProgress();

    // Back to top
    const btn = document.getElementById('back-to-top');
    if (btn) {
      const onScroll = () => btn.classList.toggle('visible', window.scrollY > 400);
      window.addEventListener('scroll', onScroll, { passive: true });
      btn.addEventListener('click', () => window.scrollTo({ top: 0, behavior: 'smooth' }));
    }

    // TOC active section tracking
    const tocLinks = document.querySelectorAll<HTMLElement>('.toc-link');
    const sectionEls = Array.from(tocLinks)
      .map((l) => (l.dataset.slug ? document.getElementById(l.dataset.slug) : null))
      .filter(Boolean) as HTMLElement[];

    if (sectionEls.length) {
      const tocObserver = new IntersectionObserver(
        (entries) => {
          for (const entry of entries) {
            if (entry.isIntersecting) {
              tocLinks.forEach((l) => l.classList.remove('active'));
              const active = Array.from(tocLinks).find((l) => l.dataset.slug === entry.target.id);
              active?.classList.add('active');
            }
          }
        },
        { rootMargin: '-20% 0px -70% 0px' }
      );
      sectionEls.forEach((el) => tocObserver.observe(el));
    }

    // Sidenotes — convert GFM footnotes to Tufte-style margin notes
    (function initSidenotes() {
      const prose = document.querySelector<HTMLElement>('.prose-content');
      if (!prose) return;
      const footnoteSection = prose.querySelector<HTMLElement>('[data-footnotes]');
      if (!footnoteSection) return;
      const fnRefs = Array.from(prose.querySelectorAll<HTMLAnchorElement>('a[data-footnote-ref]'));
      if (!fnRefs.length) return;

      fnRefs.forEach((ref) => {
        const href = ref.getAttribute('href');
        if (!href) return;
        const fnEl = document.getElementById(href.slice(1));
        if (!fnEl) return;
        const clone = fnEl.cloneNode(true) as HTMLElement;
        clone.querySelectorAll('a[data-footnote-backref]').forEach((el) => el.remove());
        const innerContent = clone.innerHTML.replace(/^\s*<p>/, '').replace(/<\/p>\s*$/, '').trim();
        const sn = document.createElement('span');
        sn.className = 'sidenote';
        sn.setAttribute('role', 'note');
        sn.innerHTML = `<span class="sidenote-num" aria-hidden="true">${ref.textContent}.</span> ${innerContent}`;
        const sup = ref.closest<HTMLElement>('sup');
        if (!sup || !sup.parentNode) return;
        sup.parentNode.insertBefore(sn, sup);
        sup.addEventListener('click', (e) => {
          if (window.innerWidth < 1400) {
            e.preventDefault();
            const prev = sup.previousElementSibling;
            if (prev?.classList.contains('sidenote')) prev.classList.toggle('open');
          }
        });
      });
      footnoteSection.style.display = 'none';
    })();

    // Copy buttons for code blocks
    document.querySelectorAll('pre').forEach((pre) => {
      if (pre.querySelector('.code-block-copy')) return;
      const btn = document.createElement('button');
      btn.className = 'code-block-copy';
      btn.textContent = 'Copy';
      btn.addEventListener('click', () => {
        const code = pre.querySelector('code')?.textContent ?? '';
        navigator.clipboard.writeText(code).then(() => {
          btn.textContent = 'Copied';
          setTimeout(() => { btn.textContent = 'Copy'; }, 1500);
        });
      });
      (pre as HTMLElement).style.position = 'relative';
      pre.appendChild(btn);
    });
  }

  wirePostPage();
  document.addEventListener('astro:page-load', wirePostPage);
</script>
