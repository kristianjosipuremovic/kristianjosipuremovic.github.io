---
import Layout from '../../../layouts/Layout.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const categories = ['ctf-writeups', 'project-writeups', 'research-writeups', 'general'];
  return categories.map(cat => ({ params: { category: cat } }));
}

const { category } = Astro.params;

const categoryLabels: Record<string, string> = {
  'ctf-writeups': 'CTF Writeups',
  'project-writeups': 'Project Writeups',
  'research-writeups': 'Research Writeups',
  'general': 'General',
};

const allPosts = await getCollection('blog');
const posts = allPosts
  .filter(p => p.data.category === category)
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

// Group series posts together
const seriesMap = new Map<string, typeof posts>();
const nonSeries: typeof posts = [];

for (const post of posts) {
  if (post.data.series) {
    const key = post.data.series;
    if (!seriesMap.has(key)) seriesMap.set(key, []);
    seriesMap.get(key)!.push(post);
  } else {
    nonSeries.push(post);
  }
}

function readingTime(body: string) {
  const words = body.split(/\s+/).length;
  return Math.max(1, Math.ceil(words / 200));
}

const label = categoryLabels[category as string] ?? category;
---

<Layout title={`${label} — Blog`} description={`All posts in ${label}`}>
  <div style="min-height:100vh; background:var(--bg); padding-top:6rem; padding-bottom:6rem;">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8 max-w-3xl">

      <div class="term-breadcrumb">
        <a href="/" class="path-dir hover:text-[var(--text)] transition-colors">~</a>
        <span class="path-sep">/</span>
        <a href="/blog" class="path-dir hover:text-[var(--text)] transition-colors">blog</a>
        <span class="path-sep">/</span>
        <span class="path-cur">{category}</span>
      </div>

      <a href="/blog" class="back-link">← All categories</a>

      <h1 class="text-3xl font-bold text-[var(--text)] mt-6 mb-2">{label}</h1>
      <p class="text-[var(--text-dim)] text-sm mb-10">{posts.length} post{posts.length !== 1 ? 's' : ''}</p>

      <!-- Series groups -->
      {Array.from(seriesMap.entries()).map(([seriesName, seriesPosts]) => (
        <div class="series-group">
          <div class="series-header">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="w-4 h-4 shrink-0">
              <path stroke-linecap="round" stroke-linejoin="round" d="M6.429 9.75L2.25 12l4.179 2.25m0-4.5l5.571 3 5.571-3m-11.142 0L2.25 7.5 12 2.25l9.75 5.25-4.179 2.25m0 0L21.75 12l-4.179 2.25m0 0l4.179 2.25L12 21.75 2.25 16.5l4.179-2.25m11.142-8.25L12 13.5" />
            </svg>
            <span>Series: {seriesName}</span>
          </div>
          {seriesPosts.sort((a, b) => (a.data.seriesPart ?? 0) - (b.data.seriesPart ?? 0)).map(post => {
            const slug = post.id.split('/').pop()!;
            return (
              <a href={`/blog/${category}/${slug}`} class="post-card" id={`post-${slug}`}>
                <div class="post-meta-row">
                  <span class="post-date">{post.data.date.toISOString().split('T')[0]}</span>
                  <span class="series-part">Part {post.data.seriesPart}</span>
                  <span class="reading-time">{readingTime(post.body ?? '')} min read</span>
                </div>
                <h2 class="post-title">{post.data.title}</h2>
                <p class="post-desc">{post.data.description}</p>
                <div class="post-tags">
                  {post.data.tags.map((t: string) => <span class="tag">{t}</span>)}
                </div>
              </a>
            );
          })}
        </div>
      ))}

      <!-- Non-series posts -->
      <div class="posts-list">
        {nonSeries.map(post => {
          const slug = post.id.split('/').pop()!;
          return (
            <a href={`/blog/${category}/${slug}`} class="post-card" id={`post-${slug}`}>
              <div class="post-meta-row">
                <span class="post-date">{post.data.date.toISOString().split('T')[0]}</span>
                <span class="reading-time">{readingTime(post.body ?? '')} min read</span>
              </div>
              <h2 class="post-title">{post.data.title}</h2>
              <p class="post-desc">{post.data.description}</p>
              <div class="post-tags">
                {post.data.tags.map((t: string) => <span class="tag">{t}</span>)}
              </div>
            </a>
          );
        })}
      </div>

    </div>
  </div>
</Layout>

<style>
  .back-link {
    font-size: 0.8rem; color: var(--text-dim); text-decoration: none;
    transition: color 0.2s ease;
  }
  .back-link:hover { color: var(--text); }

  .series-group {
    margin-bottom: 2rem;
    border: 1px solid var(--border);
    border-radius: 0.5rem;
    overflow: hidden;
  }
  .series-header {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.6rem 1rem;
    background: rgba(255,255,255,0.03);
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    color: var(--text-dim);
    border-bottom: 1px solid var(--border);
  }

  .posts-list { display: flex; flex-direction: column; gap: 0.5rem; }

  .post-card {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
    padding: 1.1rem 1.25rem;
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: 0.5rem;
    text-decoration: none;
    transition: border-color 0.2s ease, background 0.15s ease;
  }
  .series-group .post-card {
    border: none;
    border-bottom: 1px solid var(--border);
    border-radius: 0;
  }
  .series-group .post-card:last-child { border-bottom: none; }
  .post-card:hover { border-color: var(--border-hover); background: rgba(39,39,42,0.6); }
  .post-card.focused { border-color: var(--text-muted); }

  .post-meta-row {
    display: flex;
    align-items: center;
    gap: 1rem;
    flex-wrap: wrap;
  }
  .post-date { font-size: 0.7rem; color: var(--text-dimmer); }
  .series-part {
    font-size: 0.65rem; font-weight: 600; color: var(--text-dim);
    background: rgba(255,255,255,0.06); padding: 0.1rem 0.4rem; border-radius: 4px;
  }
  .reading-time { font-size: 0.68rem; color: var(--text-dimmer); margin-left: auto; }
  .post-title { font-size: 1rem; font-weight: 700; color: var(--text); line-height: 1.3; }
  .post-desc { font-size: 0.8rem; color: var(--text-dim); line-height: 1.5; }
  .post-tags { display: flex; flex-wrap: wrap; gap: 0.25rem; margin-top: 0.25rem; }
</style>

<script>
  // j/k vim keyboard navigation
  const cards = Array.from(document.querySelectorAll<HTMLElement>('.post-card'));
  let idx = -1;
  function focus(i: number) {
    cards.forEach(c => c.classList.remove('focused'));
    idx = Math.max(0, Math.min(cards.length - 1, i));
    cards[idx]?.classList.add('focused');
    cards[idx]?.scrollIntoView({ block: 'nearest', behavior: 'smooth' });
  }
  document.addEventListener('keydown', (e) => {
    if ((e.target as HTMLElement).tagName === 'INPUT') return;
    if (e.key === 'j') focus(idx + 1);
    if (e.key === 'k') focus(idx - 1);
    if (e.key === 'Enter' && idx >= 0) (cards[idx] as HTMLAnchorElement).click();
  });
</script>
