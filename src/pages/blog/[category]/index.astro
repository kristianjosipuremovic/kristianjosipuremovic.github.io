---
import Layout from '../../../layouts/Layout.astro';
import Header from '../../../components/Header.astro';
import Footer from '../../../components/Footer.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const categories = ['research-writeups', 'ctf-writeups', 'home-labs', 'general'];
  return categories.map((cat) => ({ params: { category: cat } }));
}

const { category } = Astro.params;

const categoryLabels: Record<string, string> = {
  'research-writeups': 'Research Writeups',
  'ctf-writeups':      'CTFs',
  'home-labs':         'Home Labs',
  'general':           'General',
};

const categoryNumerals: Record<string, string> = {
  'research-writeups': '01',
  'ctf-writeups':      '02',
  'home-labs':         '03',
  'general':           '04',
};

const allPosts = await getCollection('blog');
const posts = allPosts
  .filter((p) => p.data.category === category)
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

const seriesMap = new Map<string, typeof posts>();
const nonSeries: typeof posts = [];

for (const post of posts) {
  if (post.data.series) {
    const key = post.data.series;
    if (!seriesMap.has(key)) seriesMap.set(key, []);
    seriesMap.get(key)!.push(post);
  } else {
    nonSeries.push(post);
  }
}

function readingTime(body: string) {
  const words = body.split(/\s+/).length;
  return Math.max(1, Math.ceil(words / 200));
}

const label = categoryLabels[category as string] ?? (category as string);
const numeral = categoryNumerals[category as string] ?? '00';
---

<Layout title={`${label} — Writeups`} description={`All writeups in ${label}.`}>
  <div class="web-only">
    <Header />
    <main id="main-content" class="page">
      <div class="container-page narrow">

        <nav class="crumb" aria-label="Breadcrumb">
          <a href="/">~</a>
          <span class="sep">/</span>
          <a href="/blog">writeups</a>
          <span class="sep">/</span>
          <span class="cur">{category}</span>
        </nav>

        <div class="sec-head reveal">
          <span class="sec-numeral">{numeral}</span>
          <div>
            <p class="eyebrow">Writeups</p>
            <h1 class="sec-title">{label}</h1>
            <p class="sec-sub">{posts.length} post{posts.length !== 1 ? 's' : ''}.</p>
          </div>
        </div>

        {Array.from(seriesMap.entries()).map(([seriesName, seriesPosts]) => (
          <section class="series-group reveal">
            <header class="series-header">
              <span class="series-mono">Series</span>
              <span class="series-name">{seriesName}</span>
            </header>
            <div class="posts-list">
              {seriesPosts
                .sort((a, b) => (a.data.seriesPart ?? 0) - (b.data.seriesPart ?? 0))
                .map((post) => {
                  const slug = post.id.split('/').pop()!;
                  return (
                    <a href={`/blog/${category}/${slug}`} class="post-row" id={`post-${slug}`}>
                      <span class="post-date">{post.data.date.toISOString().split('T')[0]}</span>
                      <div class="post-body">
                        <div class="post-meta">
                          <span class="series-part">Part {post.data.seriesPart}</span>
                          <span class="reading-time">{readingTime(post.body ?? '')} min</span>
                        </div>
                        <h2 class="post-title">{post.data.title}</h2>
                        <p class="post-desc">{post.data.description}</p>
                      </div>
                      <span class="post-arrow" aria-hidden="true">→</span>
                    </a>
                  );
                })}
            </div>
          </section>
        ))}

        {nonSeries.length > 0 && (
          <div class="posts-list reveal">
            {nonSeries.map((post) => {
              const slug = post.id.split('/').pop()!;
              return (
                <a href={`/blog/${category}/${slug}`} class="post-row" id={`post-${slug}`}>
                  <span class="post-date">{post.data.date.toISOString().split('T')[0]}</span>
                  <div class="post-body">
                    <div class="post-meta">
                      <span class="reading-time">{readingTime(post.body ?? '')} min</span>
                    </div>
                    <h2 class="post-title">{post.data.title}</h2>
                    <p class="post-desc">{post.data.description}</p>
                  </div>
                  <span class="post-arrow" aria-hidden="true">→</span>
                </a>
              );
            })}
          </div>
        )}

        {posts.length === 0 && (
          <p class="empty">No posts in this category yet.</p>
        )}

        <div class="back-link-wrap">
          <a href="/blog" class="link-bright">← All categories</a>
        </div>

      </div>
    </main>
    <Footer />
  </div>
</Layout>

<style>
  .page { padding-top: 7rem; padding-bottom: 6rem; min-height: 100vh; background: var(--bg); }
  .container-page.narrow { max-width: 56rem; }

  .series-group {
    margin: 0 0 2.5rem;
    border: 1px solid var(--line-strong);
    padding: 0;
    clip-path: polygon(0 0, calc(100% - 14px) 0, 100% 14px, 100% 100%, 0 100%);
  }
  .series-header {
    display: flex;
    align-items: baseline;
    gap: 1rem;
    padding: 0.75rem 1.25rem;
    background: rgba(244, 244, 245, 0.03);
    border-bottom: 1px solid var(--line);
  }
  .series-mono {
    font-family: var(--font-mono);
    font-size: 0.62rem;
    letter-spacing: 0.22em;
    color: var(--text-dimmer);
    text-transform: uppercase;
  }
  .series-name {
    font-family: var(--font-display);
    font-size: 0.8rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--text);
  }

  .posts-list { display: flex; flex-direction: column; }

  .post-row {
    display: grid;
    grid-template-columns: 7rem 1fr auto;
    gap: 1.25rem;
    align-items: start;
    padding: 1.25rem 0.5rem 1.25rem 0;
    border-bottom: 1px solid var(--line);
    text-decoration: none;
    transition: background 0.25s var(--ease-shutter), padding 0.25s var(--ease-shutter);
  }
  .post-row:last-child { border-bottom: none; }
  .series-group .post-row { padding-left: 1.25rem; padding-right: 1.25rem; }
  .post-row:hover { background: rgba(244, 244, 245, 0.02); }
  .post-row.focused { background: rgba(244, 244, 245, 0.04); }

  .post-date {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    color: var(--text-dimmer);
    letter-spacing: 0.05em;
    padding-top: 0.2rem;
  }

  .post-body { display: flex; flex-direction: column; gap: 0.35rem; }

  .post-meta {
    display: flex;
    gap: 0.85rem;
    align-items: baseline;
    margin-bottom: 0.1rem;
  }
  .series-part,
  .reading-time {
    font-family: var(--font-mono);
    font-size: 0.62rem;
    letter-spacing: 0.18em;
    color: var(--text-dimmer);
    text-transform: uppercase;
  }
  .series-part {
    color: var(--text-dim);
    padding: 0.15rem 0.4rem;
    border: 1px solid var(--line);
    line-height: 1;
  }

  .post-title {
    font-family: var(--font-display);
    font-size: 1rem;
    font-weight: 600;
    letter-spacing: 0.02em;
    color: var(--text);
    margin: 0;
    line-height: 1.3;
    text-transform: none;
  }
  .post-desc {
    font-size: 0.85rem;
    color: var(--text-dim);
    line-height: 1.55;
    margin: 0;
  }

  .post-arrow {
    font-family: var(--font-mono);
    color: var(--text-dim);
    font-size: 1rem;
    padding-top: 0.2rem;
    transition: transform 0.3s var(--ease-shutter), color 0.2s ease;
  }
  .post-row:hover .post-arrow { color: var(--text); transform: translate(3px, -2px); }

  .empty {
    color: var(--text-dim);
    font-size: 0.875rem;
    text-align: center;
    padding: 4rem 0;
  }

  .back-link-wrap {
    margin-top: 3rem;
    padding-top: 1.5rem;
    border-top: 1px solid var(--line);
  }

  @media (max-width: 540px) {
    .post-row { grid-template-columns: 1fr; }
    .post-arrow { display: none; }
    .post-date { padding-top: 0; }
  }
</style>

<script>
  function wirePostNav() {
    const cards = Array.from(document.querySelectorAll<HTMLElement>('.post-row'));
    let idx = -1;
    function focus(i: number) {
      cards.forEach((c) => c.classList.remove('focused'));
      idx = Math.max(0, Math.min(cards.length - 1, i));
      cards[idx]?.classList.add('focused');
      cards[idx]?.scrollIntoView({ block: 'nearest', behavior: 'smooth' });
    }
    function handler(e: KeyboardEvent) {
      if ((e.target as HTMLElement).tagName === 'INPUT') return;
      if (e.key === 'j') focus(idx + 1);
      if (e.key === 'k') focus(idx - 1);
      if (e.key === 'Enter' && idx >= 0) (cards[idx] as HTMLAnchorElement).click();
    }
    document.addEventListener('keydown', handler);
  }
  wirePostNav();
  document.addEventListener('astro:page-load', wirePostNav);
</script>
