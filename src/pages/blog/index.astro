---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { getCollection } from 'astro:content';

const allPosts = await getCollection('blog');

const categories = [
  { slug: 'research-writeups', label: 'Research Writeups', desc: 'Field notes from active research.' },
  { slug: 'ctf-writeups',      label: 'CTFs',              desc: 'Capture-the-flag solutions and analysis.' },
  { slug: 'home-labs',         label: 'Home Labs',         desc: 'Personal experiments and lab builds.' },
  { slug: 'general',           label: 'General',           desc: 'Everything else worth recording.' },
];

function postCountFor(cat: string) {
  return allPosts.filter((p) => p.data.category === cat).length;
}

const recentPosts = [...allPosts]
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
  .slice(0, 5);
---

<Layout title="Writeups — Kristian Uremovic" description="Research notes, CTFs, home labs, and general writing.">
  <div class="web-only">
    <Header />
    <main id="main-content" class="page">
      <div class="container-page">

        <nav class="crumb" aria-label="Breadcrumb">
          <a href="/">~</a>
          <span class="sep">/</span>
          <span class="cur">writeups</span>
        </nav>

        <div class="sec-head reveal">
          <span class="sec-numeral">01</span>
          <div>
            <p class="eyebrow">Field notes</p>
            <h1 class="sec-title">Writeups</h1>
            <p class="sec-sub">
              {allPosts.length} post{allPosts.length !== 1 ? 's' : ''} across {categories.length} categories.
              Press <kbd class="kbd">Ctrl+K</kbd> to search.
            </p>
          </div>
        </div>

        <!-- Pagefind search -->
        <div id="search" class="search-wrap reveal"></div>

        <!-- Four chrome panels -->
        <div class="cat-grid">
          {categories.map((c, i) => (
            <a href={`/blog/${c.slug}`} class:list={["panel-chrome", "cat-card", "reveal", { "panel-feature": i === 0 }]}>
              <div class="cat-head">
                <span class="cat-num">{String(i + 1).padStart(2, '0')}</span>
                <span class="cat-count">{postCountFor(c.slug)} POST{postCountFor(c.slug) !== 1 ? 'S' : ''}</span>
              </div>
              <h2 class="cat-name">{c.label}</h2>
              <p class="cat-desc">{c.desc}</p>
              <span class="cat-glyph" aria-hidden="true">─→</span>
            </a>
          ))}
        </div>

        {recentPosts.length > 0 && (
          <section class="recent">
            <div class="sec-head reveal">
              <span class="sec-numeral">02</span>
              <div>
                <p class="eyebrow">Latest</p>
                <h2 class="sec-title">Recent</h2>
              </div>
            </div>
            <div class="recent-list reveal">
              {recentPosts.map((post) => {
                const slug = post.id.split('/').pop();
                return (
                  <a href={`/blog/${post.data.category}/${slug}`} class="recent-item">
                    <span class="recent-date">{post.data.date.toISOString().split('T')[0]}</span>
                    <span class="recent-title">{post.data.title}</span>
                    <span class="recent-cat">{post.data.category}</span>
                  </a>
                );
              })}
            </div>
          </section>
        )}

      </div>
    </main>
    <Footer />
  </div>
</Layout>

<style>
  .page { padding-top: 7rem; padding-bottom: 6rem; min-height: 100vh; background: var(--bg); }

  .kbd {
    background: rgba(244, 244, 245, 0.06);
    border: 1px solid var(--line-strong);
    padding: 0.1rem 0.4rem;
    font-family: var(--font-mono);
    font-size: 0.7rem;
    color: var(--text-dim);
  }

  .search-wrap { margin-bottom: 3rem; }

  /* Fragmented grid — Maxim VIII */
  .cat-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.25rem;
    margin-bottom: 5rem;
  }
  @media (min-width: 700px) {
    .cat-grid { grid-template-columns: repeat(6, 1fr); }
    .cat-grid > :nth-child(1) { grid-column: span 6; min-height: 240px; }
    .cat-grid > :nth-child(2) { grid-column: span 4; }
    .cat-grid > :nth-child(3) { grid-column: span 2; }
    .cat-grid > :nth-child(4) { grid-column: span 6; }
  }
  @media (min-width: 1024px) {
    .cat-grid { grid-template-columns: repeat(12, 1fr); }
    .cat-grid > :nth-child(1) { grid-column: span 7; }
    .cat-grid > :nth-child(2) { grid-column: span 5; }
    .cat-grid > :nth-child(3) { grid-column: span 5; }
    .cat-grid > :nth-child(4) { grid-column: span 7; }
  }

  .cat-card {
    padding: 1.85rem 2rem 2rem;
    display: flex;
    flex-direction: column;
    gap: 0.55rem;
    min-height: 200px;
    color: var(--text);
    position: relative;
  }
  .cat-head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
  }
  .cat-num {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    letter-spacing: 0.18em;
    color: var(--text-dimmer);
    padding: 0.18rem 0.45rem;
    border: 1px solid var(--line);
  }
  .cat-count {
    font-family: var(--font-mono);
    font-size: 0.65rem;
    letter-spacing: 0.18em;
    color: var(--text-dimmer);
  }
  .cat-name {
    font-family: var(--font-display);
    font-size: clamp(1.35rem, 2.2vw, 1.85rem);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.02em;
    color: var(--text);
    margin: 0.5rem 0 0;
    line-height: 1.1;
  }
  .cat-card.panel-feature .cat-name { font-size: clamp(1.6rem, 3.5vw, 2.4rem); }
  .cat-desc {
    font-size: 0.86rem;
    line-height: 1.6;
    color: var(--text-dim);
    margin: 0;
    flex: 1;
  }
  .cat-glyph {
    font-family: var(--font-mono);
    font-size: 0.85rem;
    color: var(--text-dim);
    margin-top: 1rem;
    align-self: flex-start;
    transition: color 0.25s ease, transform 0.3s var(--ease-shutter);
  }
  .cat-card:hover .cat-glyph { color: var(--text); transform: translateX(4px); }

  /* Recent posts list */
  .recent { margin-top: 4rem; }
  .recent-list { display: flex; flex-direction: column; gap: 0; }
  .recent-item {
    display: grid;
    grid-template-columns: 7rem 1fr auto;
    gap: 1rem;
    align-items: center;
    padding: 0.85rem 0;
    border-bottom: 1px solid var(--line);
    text-decoration: none;
    transition: background 0.2s ease;
  }
  .recent-item:last-child { border-bottom: none; }
  .recent-item:hover { background: rgba(244, 244, 245, 0.02); }
  .recent-date {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    color: var(--text-dimmer);
    letter-spacing: 0.04em;
  }
  .recent-title { font-size: 0.92rem; color: var(--text-body); transition: color 0.2s ease; }
  .recent-item:hover .recent-title { color: var(--text); }
  .recent-cat {
    font-family: var(--font-mono);
    font-size: 0.62rem;
    color: var(--text-dimmer);
    letter-spacing: 0.12em;
    text-transform: uppercase;
    text-align: right;
  }
  @media (max-width: 540px) {
    .recent-item { grid-template-columns: 1fr; }
    .recent-cat, .recent-date { display: none; }
  }

  /* Pagefind UI overrides — chrome aesthetic */
  #search :global(.pagefind-ui) {
    --pagefind-ui-scale: 0.85;
    --pagefind-ui-primary: var(--text);
    --pagefind-ui-text: var(--text-body);
    --pagefind-ui-background: var(--bg-elev-1);
    --pagefind-ui-border: var(--line-strong);
    --pagefind-ui-tag: rgba(244, 244, 245, 0.06);
    --pagefind-ui-border-width: 1px;
    --pagefind-ui-border-radius: 0;
    --pagefind-ui-font: var(--font-body);
  }
</style>

<script is:inline>
  (async function () {
    const el = document.getElementById('search');
    if (!el) return;
    try {
      const { PagefindUI } = await import('/pagefind/pagefind-ui.js');
      new PagefindUI({ element: '#search', showSubResults: true });
    } catch {
      el.style.display = 'none';
    }
  })();
</script>
