---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const allPosts = await getCollection('blog');

const categories = [
  { slug: 'ctf-writeups', label: 'CTF Writeups', desc: 'Capture-the-flag solutions and analysis' },
  { slug: 'project-writeups', label: 'Project Writeups', desc: 'Deep dives into personal projects' },
  { slug: 'research-writeups', label: 'Research Writeups', desc: 'Notes and findings from ongoing research' },
  { slug: 'general', label: 'General', desc: 'Everything else' },
];

function postCountFor(cat: string) {
  return allPosts.filter(p => p.data.category === cat).length;
}

const recentPosts = [...allPosts]
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
  .slice(0, 5);
---

<Layout title="Blog — Kristian Uremovic" description="CTF writeups, project notes, research findings, and general writing.">
  <div style="min-height:100vh; background:var(--bg); padding-top:6rem; padding-bottom:6rem;">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8 max-w-4xl">

      <div class="term-breadcrumb">
        <a href="/" class="path-dir hover:text-[var(--text)] transition-colors">~</a>
        <span class="path-sep">/</span>
        <span class="path-cur">blog</span>
      </div>

      <!-- Search bar (Pagefind) -->
      <div id="search" class="mb-10"></div>

      <h1 class="text-4xl font-bold text-[var(--text)] mb-2">Blog</h1>
      <p class="text-[var(--text-dim)] mb-12 text-sm">
        {allPosts.length} post{allPosts.length !== 1 ? 's' : ''} across {categories.length} categories.
        Press <kbd class="kbd">Ctrl+K</kbd> to search.
      </p>

      <!-- Category folders -->
      <div class="grid gap-4 sm:grid-cols-2 mb-16">
        {categories.map(cat => (
          <a href={`/blog/${cat.slug}`} class="blog-folder-card">
            <div class="folder-icon-row">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="w-7 h-7">
                <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 12.75V12A2.25 2.25 0 014.5 9.75h15A2.25 2.25 0 0121.75 12v.75m-8.69-6.44l-2.12-2.12a1.5 1.5 0 00-1.061-.44H4.5A2.25 2.25 0 002.25 6v12a2.25 2.25 0 002.25 2.25h15A2.25 2.25 0 0021.75 18V9a2.25 2.25 0 00-2.25-2.25h-5.379a1.5 1.5 0 01-1.06-.44z" />
              </svg>
              <span class="folder-count">{postCountFor(cat.slug)} post{postCountFor(cat.slug) !== 1 ? 's' : ''}</span>
            </div>
            <h2 class="folder-label">{cat.label}</h2>
            <p class="folder-desc">{cat.desc}</p>
            <p class="folder-path">~/blog/{cat.slug}/</p>
          </a>
        ))}
      </div>

      <!-- Recent posts -->
      {recentPosts.length > 0 && (
        <div>
          <h2 class="text-lg font-bold text-[var(--text-muted)] mb-4 uppercase tracking-widest text-xs">Recent Posts</h2>
          <div class="recent-list">
            {recentPosts.map(post => (
              <a href={`/blog/${post.data.category}/${post.id.split('/').pop()}`} class="recent-item">
                <span class="recent-date">{post.data.date.toISOString().split('T')[0]}</span>
                <span class="recent-title">{post.data.title}</span>
                <span class="recent-cat">{post.data.category}</span>
              </a>
            ))}
          </div>
        </div>
      )}
    </div>
  </div>
</Layout>

<style>
  .kbd {
    background: var(--bg-surface);
    border: 1px solid var(--border);
    border-radius: 4px;
    padding: 0.1rem 0.4rem;
    font-size: 0.72rem;
    color: var(--text-dim);
    font-family: inherit;
  }

  .blog-folder-card {
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
    padding: 1.25rem;
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: 0.5rem;
    text-decoration: none;
    transition: border-color 0.2s ease, transform 0.2s ease;
  }
  .blog-folder-card:hover { border-color: var(--border-hover); transform: translateY(-2px); }

  .folder-icon-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    color: var(--text-dim);
    margin-bottom: 0.25rem;
  }
  .folder-count { font-size: 0.68rem; color: var(--text-dimmer); }
  .folder-label { font-size: 1rem; font-weight: 700; color: var(--text); }
  .folder-desc { font-size: 0.78rem; color: var(--text-dim); }
  .folder-path { font-size: 0.65rem; color: var(--text-dimmer); margin-top: 0.5rem; }

  .recent-list { display: flex; flex-direction: column; gap: 0; }
  .recent-item {
    display: grid;
    grid-template-columns: 6.5rem 1fr auto;
    gap: 1rem;
    align-items: center;
    padding: 0.6rem 0;
    border-bottom: 1px solid var(--border);
    text-decoration: none;
    transition: background 0.15s ease;
  }
  .recent-item:hover { background: rgba(255,255,255,0.02); }
  .recent-item:last-child { border-bottom: none; }
  .recent-date { font-size: 0.7rem; color: var(--text-dimmer); white-space: nowrap; }
  .recent-title { font-size: 0.85rem; color: var(--text-muted); transition: color 0.2s ease; }
  .recent-item:hover .recent-title { color: var(--text); }
  .recent-cat { font-size: 0.65rem; color: var(--text-dimmer); text-align: right; white-space: nowrap; }

  @media (max-width: 480px) {
    .recent-item { grid-template-columns: 1fr; }
    .recent-cat { display: none; }
  }

  /* Pagefind UI overrides */
  #search .pagefind-ui {
    --pagefind-ui-scale: 0.8;
    --pagefind-ui-primary: var(--text);
    --pagefind-ui-text: var(--text-muted);
    --pagefind-ui-background: var(--bg-card);
    --pagefind-ui-border: var(--border);
    --pagefind-ui-tag: var(--bg-surface);
    --pagefind-ui-border-width: 1px;
    --pagefind-ui-border-radius: 0.5rem;
    --pagefind-ui-font: inherit;
  }
</style>

<script is:inline>
  (async function() {
    const el = document.getElementById('search');
    if (!el) return;
    try {
      const { PagefindUI } = await import('/pagefind/pagefind-ui.js');
      new PagefindUI({ element: '#search', showSubResults: true });
    } catch {
      // Pagefind not available in dev — only available after build
      el.style.display = 'none';
    }
  })();
</script>
