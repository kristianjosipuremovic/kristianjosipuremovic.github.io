---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const books: Record<string, { title: string; author: string; status: string }[]> = {
  'Cybersecurity': [
    { title: 'Countdown to Zero Day',  author: 'Kim Zetter',                                       status: 'To Read' },
    { title: 'Sandworm',               author: 'Andy Greenberg',                                   status: 'To Read' },
    { title: 'Chip War',               author: 'Chris Miller',                                     status: 'To Read' },
    { title: "The Cuckoo's Egg",       author: 'Cliff Stoll',                                      status: 'To Read' },
    { title: 'The Seventh Sense',      author: 'Joshua Cooper Ramo',                               status: 'To Read' },
    { title: 'The Sovereign Individual', author: 'James Dale Davidson & Lord William Rees-Mogg',   status: 'To Read' },
  ],
};
---

<Layout title="Reading — Kristian Uremovic" description="Books I've read, am reading, or plan to read.">
  <div class="web-only">
    <Header />
    <main id="main-content" class="page">
      <div class="container-page narrow">

        <nav class="crumb" aria-label="Breadcrumb">
          <a href="/">~</a>
          <span class="sep">/</span>
          <span class="cur">reading</span>
        </nav>

        <div class="sec-head reveal">
          <span class="sec-numeral">01</span>
          <div>
            <p class="eyebrow">Library</p>
            <h1 class="sec-title">Reading</h1>
            <p class="sec-sub">A living shelf — books that shape current thinking.</p>
          </div>
        </div>

        {Object.entries(books).map(([category, list], i) => (
          <section class="cat-block reveal">
            <header class="cat-head">
              <span class="cat-num">{String(i + 1).padStart(2, '0')}</span>
              <h2 class="cat-label">{category}</h2>
            </header>
            <table class="hair-table book-table">
              <tbody>
                {list.map((book) => (
                  <tr>
                    <th>{book.title}</th>
                    <td class="book-author">{book.author}</td>
                    <td class="book-status"><span class="status-label">{book.status}</span></td>
                  </tr>
                ))}
              </tbody>
            </table>
          </section>
        ))}

      </div>
    </main>
    <Footer />
  </div>
</Layout>

<style>
  .page { padding-top: 7rem; padding-bottom: 6rem; min-height: 100vh; background: var(--bg); }
  .container-page.narrow { max-width: 56rem; }

  .cat-block { margin: 2.5rem 0 3rem; }
  .cat-head {
    display: flex;
    align-items: baseline;
    gap: 1rem;
    margin-bottom: 1rem;
    padding-bottom: 0.6rem;
    border-bottom: 1px solid var(--line);
  }
  .cat-num {
    font-family: var(--font-mono);
    font-size: 0.62rem;
    letter-spacing: 0.2em;
    color: var(--text-dimmer);
    padding: 0.18rem 0.4rem;
    border: 1px solid var(--line);
    line-height: 1;
  }
  .cat-label {
    font-family: var(--font-display);
    font-size: 0.85rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.18em;
    color: var(--text);
    margin: 0;
  }

  .book-table th { width: 50%; color: var(--text); font-family: var(--font-display); text-transform: none; letter-spacing: 0; font-size: 0.92rem; font-weight: 500; }
  .book-author { color: var(--text-dim); font-size: 0.85rem; }
  .book-status { text-align: right; width: 8rem; }
  @media (max-width: 540px) {
    .book-table th { width: 65%; font-size: 0.85rem; }
    .book-author { display: none; }
  }
</style>
