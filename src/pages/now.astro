---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const sections = [
  {
    label: 'Studying',
    items: ['Cryptography', 'Unix Systems Administration'],
  },
  {
    label: 'Building',
    items: ['GCC flag simulation repository', 'CERIAS binary hardening benchmarking'],
  },
  {
    label: 'Training',
    items: ['Powerlifting', 'Judo', 'Soccer'],
  },
];
---

<Layout title="Now — Kristian Uremovic" description="What I'm currently focused on.">
  <div class="web-only">
    <Header />
    <main id="main-content" class="page">
      <div class="container-page narrow">

        <nav class="crumb" aria-label="Breadcrumb">
          <a href="/">~</a>
          <span class="sep">/</span>
          <span class="cur">now</span>
        </nav>

        <div class="sec-head reveal">
          <span class="sec-numeral">01</span>
          <div>
            <p class="eyebrow">Status</p>
            <h1 class="sec-title">Now</h1>
            <p class="sec-sub">
              Updated May 2026 ·
              <a href="https://nownownow.com/about" target="_blank" rel="noopener" class="link-bright">What is a now page?</a>
            </p>
          </div>
        </div>

        <div class="now-grid">
          {sections.map((s, i) => (
            <section class="panel-chrome now-card reveal" style={`transition-delay: ${i * 0.05}s;`}>
              <div class="now-head">
                <span class="now-num">{String(i + 1).padStart(2, '0')}</span>
                <h2 class="now-label">{s.label}</h2>
              </div>
              <ul class="now-list">
                {s.items.map((item) => (
                  <li class="now-item">{item}</li>
                ))}
              </ul>
            </section>
          ))}
        </div>

        <div class="rule-diagonal" aria-hidden="true"></div>

        <div class="now-foot reveal">
          <a href="/reading" class="link-bright">→ Reading list</a>
        </div>
      </div>
    </main>
    <Footer />
  </div>
</Layout>

<style>
  .page { padding-top: 7rem; padding-bottom: 6rem; min-height: 100vh; background: var(--bg); }
  .container-page.narrow { max-width: 56rem; }

  .now-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.25rem;
    margin-bottom: 3.5rem;
  }
  @media (min-width: 700px) {
    .now-grid { grid-template-columns: repeat(2, 1fr); }
    .now-grid > :nth-child(1) { grid-column: 1 / -1; }
  }
  @media (min-width: 1024px) {
    .now-grid { grid-template-columns: repeat(3, 1fr); }
    .now-grid > :nth-child(1) { grid-column: span 3; }
    .now-grid > :nth-child(2) { grid-column: span 2; }
    .now-grid > :nth-child(3) { grid-column: span 1; }
  }

  .now-card {
    padding: 1.5rem 1.75rem 1.7rem;
    display: flex;
    flex-direction: column;
    gap: 0.85rem;
    min-height: 180px;
  }
  .now-head {
    display: flex;
    align-items: baseline;
    gap: 0.85rem;
  }
  .now-num {
    font-family: var(--font-mono);
    font-size: 0.65rem;
    letter-spacing: 0.2em;
    color: var(--text-dimmer);
    padding: 0.18rem 0.4rem;
    border: 1px solid var(--line);
    line-height: 1;
  }
  .now-label {
    font-family: var(--font-display);
    font-size: 0.78rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.18em;
    color: var(--text);
    margin: 0;
  }

  .now-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }
  .now-item {
    font-size: 0.92rem;
    color: var(--text-body);
    padding-left: 1rem;
    position: relative;
  }
  .now-item::before {
    content: "—";
    position: absolute;
    left: 0;
    color: var(--text-dimmer);
  }

  .now-foot {
    margin-top: 2rem;
    font-size: 0.85rem;
    color: var(--text-dim);
  }
</style>
